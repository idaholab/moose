# MooseConfig.cmake (installed) -- relocatable find_package(Moose) entry point.
#
# Installed layout (relative to this file at <prefix>/lib/cmake/moose):
#   <prefix>/lib/moose/lib{moose,hit}-<method>.<so|dylib>
#   <prefix>/include/moose/**            (framework + contrib + generated headers)
#   <prefix>/lib/cmake/moose/modules/    (the Moose* cmake helpers)
#
# The consuming project must set the libMesh toolchain before its project() call:
#   list(PREPEND CMAKE_MODULE_PATH "<prefix>/lib/cmake/moose/modules")
#   include(MooseMethods); include(MooseLibMesh); moose_libmesh_set_compilers()

set(_moose_prefix "${CMAKE_CURRENT_LIST_DIR}/../../..")
get_filename_component(_moose_prefix "${_moose_prefix}" ABSOLUTE)

list(PREPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/modules")
if(NOT DEFINED MOOSE_METHOD)
  set(MOOSE_METHOD "@MOOSE_METHOD@")
endif()
set(MOOSE_FRAMEWORK_SCRIPTS "@MOOSE_FRAMEWORK_SCRIPTS@")

include(MooseMethods)
include(MooseUtils)
include(MooseLibMesh)
include(MooseWasp)
include(MooseApp)

if(NOT TARGET MOOSE::libmesh)
  moose_libmesh_create_target()
endif()
if(NOT TARGET MOOSE::wasp)
  moose_create_wasp_target()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/MooseTargets-${MOOSE_METHOD}.cmake")

# Re-add the header search paths from the installed tree (every subdir, since MOOSE headers
# are included by bare name) plus the force-included MooseConfig.h -- the install-stripped
# equivalents of the build-tree usage requirements.
set(_moose_inc "${_moose_prefix}/include/moose")
moose_collect_subdirs(_moose_inc_dirs "${_moose_inc}")
set_property(TARGET Moose::moose APPEND PROPERTY INTERFACE_INCLUDE_DIRECTORIES ${_moose_inc_dirs})
set_property(TARGET Moose::moose APPEND PROPERTY INTERFACE_COMPILE_OPTIONS
  "$<$<COMPILE_LANGUAGE:CXX>:SHELL:-include ${_moose_inc}/MooseConfig.h>")
