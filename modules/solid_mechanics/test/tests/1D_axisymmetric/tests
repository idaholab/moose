[Tests]
  issues = '#8045 #14606'
  [axisymmetric_gps_incremental]
    type = 'Exodiff'
    input = 'axisymmetric_gps_incremental.i'
    exodiff = 'axisymmetric_gps_incremental_out.e'
    design = 'GeneralizedPlaneStrainAction.md'
    requirement = 'The system shall support generalized plane strain with incremental strain for 1D meshes using the SolidMechanics/QuasiStatic Physics.'
  []
  [axisymmetric_gps_incremental_ad]
    type = 'Exodiff'
    input = 'axisymmetric_gps_incremental.i'
    cli_args = 'Physics/SolidMechanics/QuasiStatic/gps/use_automatic_differentiation=true
                Materials/elasticity_tensor/type=ADComputeIsotropicElasticityTensor
                Materials/thermal_strain/type=ADComputeThermalExpansionEigenstrain
                Materials/stress/type=ADComputeStrainIncrementBasedStress
                Outputs/file_base=axisymmetric_gps_incremental_out'
    exodiff = 'axisymmetric_gps_incremental_out.e'
    prereq = axisymmetric_gps_incremental
    design = 'GeneralizedPlaneStrainAction.md source/materials/ComputeAxisymmetric1DIncrementalStrain.md'
    requirement = 'The system shall support AD generalized plane strain with incremental strain for 1D meshes using the SolidMechanics/QuasiStatic Physics.'
  []
  [axisymmetric_gps_incremental_ad_jacobian]
    type = 'PetscJacobianTester'
    input = 'axisymmetric_gps_ad_jacobian.i'
    cli_args = 'Physics/SolidMechanics/QuasiStatic/gps/incremental=true
                Materials/stress/type=ADComputeStrainIncrementBasedStress'
    run_sim = 'True'
    ratio_tol = 1e-7
    difference_tol = 1e-4
    design = 'source/kernels/ADStressDivergenceRZTensors.md source/kernels/ADGeneralizedPlaneStrain.md source/materials/ComputeAxisymmetric1DIncrementalStrain.md'
    requirement = 'The system shall compute the Jacobian for AD 1D axisymmetric generalized plane strain with incremental strain.'
  []
  [axisymmetric_gps_small]
    type = 'Exodiff'
