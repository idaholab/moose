[Tests]
  issues = '#29382'
  design = 'AbaqusUELMeshUserElement.md AbaqusEssentialBC.md AbaqusForceBC.md'

  # Ideally we should use a space-filling curve partitioner in all tests, so libsfcurves must be available for parallel runs
  # capabilities = 'installation_type=in_tree & (mpi_procs=1 | sfcurves)'

  # Unfortunately the sfc library is not LGPL and is not distributed with libmesh by default, so we use a crude linear partitioner
  capabilities = 'installation_type=in_tree'

  [build_uel_plugin_opt]
    type = RunCommand
    command = "cd elasticity_uel; make"
    use_shell = True
    requirement = "The elastic UEL test plugin shall be built in opt."
    # skip test if test is being run out-of-tree. Issue Ref: #25279
    capabilities = 'installation_type=in_tree & method=opt'
  []
  [build_uel_plugin_dbg]
    type = RunCommand
    command = "cd elasticity_uel; make METHOD=dbg"
    use_shell = True
    requirement = "The elastic UEL test plugin shall be built in dbg."
    # skip test if test is being run out-of-tree. Issue Ref: #25279
    capabilities = 'installation_type=in_tree & method=dbg'
  []

  [mesh_only]
    type = Exodiff
    input = abaqus_uel_read.i
    exodiff = abaqus_uel_read_in.e
    cli_args = '--mesh-only'
    requirement = 'The system shall be able to load an Abaqus input file with UEL user elements.'
  []

  [big_test]
    type = Exodiff
    abs_zero = 1e-9
    input = test.i
    exodiff = test_out.e
    requirement = 'The system shall be able to run a larger Abaqus UEL simulation with space filling curve partitioning.'
  []

  [elastic_bc]
    type = Exodiff
    abs_zero = 1e-9
    input = elastic.i
    exodiff = elastic_out.e
    requirement = 'The system shall be able to apply essential boundary conditions from an Abaqus input file with UEL user elements.'
  []
  [elastic_action_bc]
    type = Exodiff
    abs_zero = 1e-9
    input = elastic_action.i
    exodiff = elastic_action_out.e
    requirement = 'The system shall be able to apply essential boundary conditions set up by an action from an Abaqus input file with UEL user elements.'
  []

  [patch_uel]
    type = Exodiff
    abs_zero = 1e-9
    input = abaqus_uel_read.i
    exodiff = PATCH_UEL_out.e
    cli_args = 'Outputs/file_base=PATCH_UEL_out'
    requirement = 'The system shall be able to load an Abaqus input file with a UEL user element applied to multiple mesh elements and apply displacement boundary conditions.'
  []
  [patch_uel_csv]
    type = CSVDiff
    input = abaqus_uel_read.i
    csvdiff = PATCH_UEL_out_statev_0010.csv
    cli_args = 'Outputs/file_base=PATCH_UEL_out'
    requirement = 'The system shall be able to load an Abaqus input file with a UEL user element applied to multiple mesh elements and apply displacement boundary conditions and output UEL state variables.'
    prereq ='patch_uel'
  []

  [multistep_uel]
    type = Exodiff
    abs_zero = 1e-9
    input = abaqus_uel_read.i
    exodiff = CUBE_UEL_BCS_out.e
    cli_args = 'Outputs/file_base=CUBE_UEL_BCS_out Mesh/file=CUBE_UEL_BCS.inp Executioner/dt=0.5 Executioner/end_time=3.0'
    requirement = 'The system shall be able to load an Abaqus input file with a UEL user element and apply distributed loads that vary over multiple steps.'
  []
  [multistep_uel_csv]
    type = CSVDiff
    input = abaqus_uel_read.i
    csvdiff = CUBE_UEL_BCS_out_statev_0006.csv
    cli_args = 'Outputs/file_base=CUBE_UEL_BCS_out Mesh/file=CUBE_UEL_BCS.inp Executioner/dt=0.5 Executioner/end_time=3.0'
    requirement = 'The system shall be able to load an Abaqus input file with a UEL user element and apply distributed loads that vary over multiple steps and output UEL state variables.'
    prereq = 'multistep_uel'
  []
[]
