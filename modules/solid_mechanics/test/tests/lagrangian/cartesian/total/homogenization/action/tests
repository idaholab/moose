[Tests]
  issues = '#17473'
  design = 'source/actions/TensorMechanicsAction.md'
  [compare_3d]
    type = Exodiff
    input = 'action_3d.i'
    exodiff = '3d.e'
    requirement = "Action produces identical results for a 3D, large deformation problem with mixed "
                  "constraints compared to a case where the components are specified manually."
    abs_zero = 1e-6
    heavy = true
  []
  [compare_2d]
    type = Exodiff
    input = 'action_2d.i'
    exodiff = '2d.e'
    requirement = "Action produces identical results for a 2D, small deformation problem with mixed "
                  "constraints compared to a case where the components are specific manually."
    abs_zero = 1e-6
    heavy = true
  []
  [mixed_pbc_symmetry_2d]
    type = Exodiff
    input = '2d_pbc_symmetry.i'
    exodiff = '2d_pbc_symmetry_out.e'
    # abs_zero / rel_err loosened (in Step 1.1) to accommodate O(1e-7) Newton-convergence-path
    # differences from the new direct-chain temperature Jacobian. Step 1.2 made the
    # displacement Jacobian also mathematically exact (F-bar tangent), but the converged
    # near-zero values (strain_yy ~ 3e-6 with absolute diff ~2e-7) still cross the default
    # relative threshold. Both Jacobians match FD; the diff is purely Newton iteration noise.
    abs_zero = 1e-5
    rel_err = 5e-3
    requirement = 'Action supports the application of periodic strain conditions and symmetry in 2D.'
  []
[]
