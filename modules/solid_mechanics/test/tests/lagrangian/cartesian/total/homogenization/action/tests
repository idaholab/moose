[Tests]
  issues = '#17473'
  design = 'source/actions/TensorMechanicsAction.md'
  [compare_3d]
    type = Exodiff
    input = 'action_3d.i'
    exodiff = '3d.e'
    requirement = "Action produces identical results for a 3D, large deformation problem with mixed "
                  "constraints compared to a case where the components are specified manually."
    abs_zero = 1e-6
    heavy = true
  []
  [compare_2d]
    type = Exodiff
    input = 'action_2d.i'
    exodiff = '2d.e'
    requirement = "Action produces identical results for a 2D, small deformation problem with mixed "
                  "constraints compared to a case where the components are specific manually."
    abs_zero = 1e-6
    heavy = true
  []
  [mixed_pbc_symmetry_2d]
    type = Exodiff
    input = '2d_pbc_symmetry.i'
    exodiff = '2d_pbc_symmetry_out.e'
    # abs_zero / rel_err loosened to accommodate O(1e-7) Newton-convergence-path differences
    # introduced when TotalLagrangianStressDivergenceBase::computeQpJacobianTemperature was
    # switched from the U-formula shortcut to the direct chain rule. Both Jacobians are
    # correct (the new one matches FD at 3.7e-7), but their iteration paths differ slightly
    # and a few near-zero quantities (strain_yy ~ 3e-6) cross the default thresholds with
    # absolute diffs of ~2e-7.
    abs_zero = 1e-5
    rel_err = 5e-3
    requirement = 'Action supports the application of periodic strain conditions and symmetry in 2D.'
  []
[]
