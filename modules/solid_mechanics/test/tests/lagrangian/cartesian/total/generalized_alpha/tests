[Tests]
  issues = '#33005'
  design = 'source/materials/lagrangian/ComputeLagrangianStrain.md'
  [alpha_1p0]
    type = CSVDiff
    input = 'alpha_check.i'
    cli_args = "GlobalParams/alpha=1.0 Outputs/file_base=alpha_1p0_out"
    csvdiff = 'alpha_1p0_out.csv'
    abs_zero = 1e-10
    requirement = 'With alpha = 1.0 (backward Euler default) the deformation_gradient and '
                  'actual_deformation_gradient material properties at a single-element ramped '
                  'uniaxial extension match the analytical sequence F_{11} = 1 + 0.01 * t'
  []
  [alpha_0p5]
    type = CSVDiff
    input = 'alpha_check.i'
    cli_args = "GlobalParams/alpha=0.5 Outputs/file_base=alpha_0p5_out"
    csvdiff = 'alpha_0p5_out.csv'
    abs_zero = 1e-10
    requirement = 'With alpha = 0.5 (generalized midpoint) the alpha-weighted '
                  'deformation_gradient matches F^alpha_{11} = 1 + 0.5*(0.01*t_n) + '
                  '0.5*(0.01*t_{n-1}) and actual_deformation_gradient matches F^actual_{11} = '
                  '1 + 0.01*t_n at each step of a single-element ramped uniaxial extension'
  []
[]
