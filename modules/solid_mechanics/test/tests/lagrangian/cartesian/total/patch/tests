[Tests]
  issues = '#17472'
  design = 'source/kernels/lagrangian/TotalLagrangianStressDivergence.md'
  [small]
    type = Exodiff
    input = 'small_patch.i'
    exodiff = 'small_patch_out.e'
    requirement = "Small strain uniaxial patch test passes with the total Lagrangian formulation"
    abs_zero = 1e-6
  []
  [large]
    type = Exodiff
    input = 'large_patch.i'
    exodiff = 'large_patch_out.e'
    requirement = "Large strain uniaxial patch test passes with the total Lagrangian formulation"
    abs_zero = 1e-6
  []
  [residual_jacobian_together]
    type = Exodiff
    prereq = large
    input = 'large_patch.i'
    exodiff = 'large_patch_out.e'
    cli_args = 'Executioner/residual_and_jacobian_together=true'
    requirement = "The new system shall produce the correct results if residual and jacobian are "
                  "computed together with the total Lagrangian formulation."
    abs_zero = 1e-6
  []
  [large_kinematics_mismatch]
    type = RunException
    input = 'large_patch.i'
    cli_args = 'Materials/compute_stress/large_kinematics=false'
    expect_err = "disagrees with the ComputeLagrangianStrain calculator"
    issues = '#33006'
    design = 'source/materials/lagrangian/ComputeLagrangianLinearElasticStress.md'
    requirement = "The Lagrangian stress calculator shall error if its deprecated large_kinematics "
                  "parameter disagrees with the value derived from the strain calculator's guarantee."
  []
[]
