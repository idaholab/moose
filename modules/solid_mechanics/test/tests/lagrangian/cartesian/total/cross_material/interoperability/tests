[Tests]
  issues = '#17472'
  design = 'source/materials/lagrangian/ComputeLagrangianWrappedStress.md'
  [manual_TaylorExpansion_no_stab]
    type = CSVDiff
    input = 'new_system_manual.i'
    csvdiff = 'TaylorExpansion_no_stabilization.csv'
    requirement = "Large deformation kinematics give equivalent results for the same kinematics, no stabilization"
    capabilities = 'method!=dbg'
    cli_args = "Materials/compute_stress/objective_rate=rashid Materials/compute_strain/kinematic_approximation=rashid_approximate Outputs/compare/file_base=TaylorExpansion_no_stabilization"
  []
  [manual_EigenSolution_no_stab]
    type = CSVDiff
    input = 'new_system_manual.i'
    csvdiff = 'EigenSolution_no_stabilization.csv'
    requirement = "Large deformation kinematics give equivalent results for the same kinematics, no stabilization"
    capabilities = 'method!=dbg'
    cli_args = "Materials/compute_stress/objective_rate=rashid Materials/compute_strain/kinematic_approximation=rashid_eigen Outputs/compare/file_base=EigenSolution_no_stabilization"
  []
  [manual_TaylorExpansion_with_stab]
    type = CSVDiff
    input = 'new_system_manual.i'
    csvdiff = 'TaylorExpansion_with_stabilization.csv'
    requirement = "Large deformation kinematics, with stabilization, produce results compatible "
                  "with the old kernel system when using `F_bar_mode = incremental` (the OLD-compat "
                  "F-bar averages the incremental F, matching `ComputeFiniteStrain` + "
                  "`volumetric_locking_correction = true`)."
    capabilities = 'method!=dbg'
    cli_args = "Materials/compute_stress/objective_rate=rashid Materials/compute_strain/kinematic_approximation=rashid_approximate Outputs/compare/file_base=TaylorExpansion_with_stabilization GlobalParams/stabilize_strain=true GlobalParams/F_bar_mode=incremental"
    # Residual diff vs OLD comes from the deliberate axial-vector-based theta formula in
    # `computeRashidApproximateIncrement` (vs. OLD's trace-based form); F-bar itself is
    # equivalent. Tolerance loosened just enough to accommodate that piece.
    rel_err = 3.0E-5
  []
  [manual_EigenSolution_with_stab]
    type = CSVDiff
    input = 'new_system_manual.i'
    csvdiff = 'EigenSolution_with_stabilization.csv'
    requirement = "Large deformation kinematics, with stabilization, produce results compatible "
                  "with the old kernel system when using `F_bar_mode = incremental` (EigenSolution "
                  "polar-decomposition variant)."
    capabilities = 'method!=dbg'
    cli_args = "Materials/compute_stress/objective_rate=rashid Materials/compute_strain/kinematic_approximation=rashid_eigen Outputs/compare/file_base=EigenSolution_with_stabilization GlobalParams/stabilize_strain=true GlobalParams/F_bar_mode=incremental"
    rel_err = 3.0E-5
  []
  [manual_TaylorExpansion_plasticity]
    type = CSVDiff
    input = 'new_system_manual_plasticity.i'
    csvdiff = 'TaylorExpansion_plasticity.csv'
    requirement = "Large deformation kinematics with plasticity produces results compatible with "
                  "the old system (rashid_approximate kinematic / OLD TaylorExpansion decomp). The "
                  "test demonstrates that NEW's Lagrangian pipeline (TL kernel + ComputeLagrangianStrain "
                  "+ ComputeLagrangianWrappedStress around ComputeMultiPlasticityStress) tracks the OLD "
                  "system (StressDivergenceTensors on displaced mesh + ComputeFiniteStrain + "
                  "ComputeMultiPlasticityStress) at the rashid_approximate / TaylorExpansion polynomial "
                  "rotation level."
    cli_args = "Materials/compute_stress/objective_rate=rashid Materials/compute_strain/kinematic_approximation=rashid_approximate Outputs/compare/file_base=TaylorExpansion_plasticity GlobalParams/stabilize_strain=true GlobalParams/F_bar_mode=incremental"
  []
  [manual_EigenSolution_plasticity]
    type = CSVDiff
    input = 'new_system_manual_plasticity.i'
    csvdiff = 'EigenSolution_plasticity.csv'
    requirement = "Large deformation kinematics with plasticity produces results identical to the "
                  "old system (rashid_eigen kinematic / OLD EigenSolution decomp) when the strain "
                  "calc publishes a real rotation_increment and the rate runs in rotate_old_stress "
                  "passthrough mode."
    cli_args = "Materials/compute_stress/objective_rate=rashid Materials/compute_strain/kinematic_approximation=rashid_eigen Outputs/compare/file_base=EigenSolution_plasticity GlobalParams/stabilize_strain=true GlobalParams/F_bar_mode=incremental"
  []
[]
