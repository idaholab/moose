[Tests]
  issues = '#27493'
  design = 'NEML2/index.md NEML2Action.md'
  [approx_kinematics]
    type = Exodiff
    requirement = 'The system shall be capable of interfacing with the NEML2 library to perform constitutive update to model crystal plasticity with approximate kinematics.'
    input = 'approx_kinematics.i'
    exodiff = 'approx_kinematics_out.e'
    capabilities = 'libtorch & neml2'
    valgrind = heavy
  []
  [exact_kinematics]
    type = Exodiff
    requirement = 'The system shall be capable of interfacing with the NEML2 library to perform constitutive update to model crystal plasticity with exact kinematics.'
    input = 'exact_kinematics.i'
    exodiff = 'exact_kinematics_out.e'
    capabilities = 'libtorch & neml2'
    valgrind = heavy
  []
  [approx_kinematics_jacobian]
    type = PetscJacobianTester
    requirement = 'The TL Jacobian assembled through ComputeLagrangianCauchyCustomStress is '
                  'consistent with the finite-differenced Jacobian to within NEML2 AD noise at '
                  'every nonlinear iteration of every load step, including steps that consume '
                  'non-zero old state (plastic_defgrad, orientation, slip_hardening).'
    input = 'approx_kinematics.i'
    run_sim = true
    ratio_tol = 5E-5
    difference_tol = 1E10
    capabilities = 'neml2'
    heavy = true
  []
  [exact_kinematics_jacobian]
    type = PetscJacobianTester
    requirement = 'The TL Jacobian assembled through ComputeLagrangianStressCustomPK2 is '
                  'consistent with the finite-differenced Jacobian to within NEML2 AD noise at '
                  'every nonlinear iteration of every load step, including steps that consume '
                  'non-zero old state (plastic_defgrad, tauc).'
    input = 'exact_kinematics.i'
    run_sim = true
    ratio_tol = 5E-5
    difference_tol = 1E10
    capabilities = 'neml2'
    heavy = true
  []
[]
