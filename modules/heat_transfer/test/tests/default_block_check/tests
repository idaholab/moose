[Tests]
  issues = '#30300'
  design = ''
  [./block_test]
    requirement = 'This regression test is designed to check the functionality of the default_block in [Problem] can help us (1) default_block become the only list of blocks in the input file for the kernel and material converage to check with. (2) default_block become the block restriction to the kernel and variable'
    [./default_block]
      type = 'Exodiff'
      input = 'convection-with-null-material.i'
      exodiff = 'convection-with-null-material_out.e'
      detail = 'check the functionality of the default_block in [Problem].'
    [../]
    [./different_kernel_different_blocks]
      type = 'Exodiff'
      input = 'convection-with-null-material-different-kernel-differnt-blocks.i'
      exodiff = 'convection-with-null-material-different-kernel-differnt-blocks_out.e'
      detail = 'check the functionality of the user setting different kernel with the blocks as long as the block id belong to the default_block list.'
    [../]
    [./kernel-coverage-override]
      type = 'Exodiff'
      input = 'convection-with-null-material-kernel-coverage-override.i'
      exodiff = 'convection-with-null-material-kernel-coverage-override_out.e'
      detail = 'check whether the code allow kernel coverage override even though we have set default_block.'
      requirement = NONE
    [../]
  [../]
  [./error_test]
    requirement = 'The system shall throw an error if if the supplied block in kernel or variable is not a subset of the default block list'
    [error]
      type = RunException
      input = 'convection-with-null-material-more-blocks-in-kernel.i'
      expect_err = 'The supplied block list is not a subset of the default block list'
      detail = 'throw an error if block inside kernel is not within the subset of the default block list.'
    []
    [error_no_default_block]
      type = RunException
      input = 'convection-with-null-material-no-default-block.i'
      expect_err = 'The following blocks from your input mesh do not contain an active material'
      detail = 'throw an error if block inside kernel is not within the subset of the default block list (This case is that we do not set the default_block in [Problem]).'
    []
  []
[]
