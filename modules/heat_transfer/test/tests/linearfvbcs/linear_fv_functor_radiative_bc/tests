[Tests]
  design = 'LinearFVFunctorRadiativeBC.md'
  issues = '#32423'
  [hot_body_cooling]
    type = CSVDiff
    input = 'linear_fv_functor_radiative_bc.i'
    csvdiff = 'linear_fv_functor_radiative_bc_hot_body_out.csv'
    max_threads = 1
    requirement = 'The system shall be able to apply a linearized radiative heat flux boundary condition
                   in the linear finite volume system to solve a conduction-radiation problem, converging via pseudo-transient iteration
                   to a steady-state temperature distribution.'
  []
  [equilibrium]
    type = CSVDiff
    input = 'linear_fv_functor_radiative_bc.i'
    csvdiff = 'linear_fv_functor_radiative_bc_eq_out.csv'
    cli_args = 'T_L=500 T_inf=500 Outputs/file_base=linear_fv_functor_radiative_bc_eq_out'
    max_threads = 1
    requirement = 'The system shall produce zero net radiative flux and a uniform temperature
                   field when the surface temperature equals the ambient temperature,
                   verifying the correct limiting behavior of the boundary condition.'
  []
  [second_order_convergence]
    type = PythonUnitTest
    input = 'test_convergence.py'
    max_threads = 1
    capabilities = 'installation_type=in_tree'
    requirement = 'The system shall achieve second-order spatial accuracy (O(h^2) convergence
                   in the L2 norm) for the radiative boundary condition on manufactured solutions
                   with for both 1D and 2D spatially varying temperature manufactured solutions.'
  []
[]
