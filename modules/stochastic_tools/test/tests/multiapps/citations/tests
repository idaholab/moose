[Tests]
  design = 'SamplerFullSolveMultiApp.md MooseApp.md'
  issues = '#33116'

  [sampler_check_input]
    type = RunApp
    input = sampler_check_input.i
    cli_args = '--check-input --citations'
    expect_out = 'harbour2025moose'
    recover = false
    requirement = "The system shall collect citations without solving when sampler MultiApp "
                  "subapps must be created during the --check-input path."
  []
  [sampler_check_input_backend]
    type = RunApp
    input = sampler_check_input.i
    cli_args = "MultiApps/sub/input_files=mfem_citations_sub.i sub0:Outputs/active='' "
               "--check-input --citations"
    expect_out = 'mfem-2024'
    capabilities = 'mfem'
    recover = false
    requirement = "The system shall report citations for backends used only inside sampler "
                  "MultiApp subapps when the --check-input and --citations command-line options "
                  "are provided."
  []
[]
