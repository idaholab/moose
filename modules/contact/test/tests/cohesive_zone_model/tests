[Tests]
  issues = '#26283'
  design = 'userobjects/BilinearMixedModeCohesiveZoneModel.md '
           'auxkernels/CohesiveZoneMortarUserObjectAux.md'
  [only_czm]
    type = Exodiff
    input = bilinear_mixed_mortar_only_czm.i
    exodiff = bilinear_mixed_mortar_only_czm_out.e
    requirement = 'The system shall be able to apply cohesive zone modeling with bilinear mixed mode '
                  'traction to a simple model.'
    abs_zero = 1.0e-6
    map = false

  []
  [czm_contact]
    type = Exodiff
    input = bilinear_mixed_mortar_only_czm.i
    exodiff = bilinear_mixed_mortar_only_czm_contact_out.e
    requirement = 'The system shall be able to apply cohesive zone modeling with bilinear mixed mode '
                  'traction and mechanical contact to a simple model.'
    cli_args = "UserObjects/czm_uo/penalty=1e6 UserObjects/czm_uo/penalty_friction=0.0 Outputs/file_base=bilinear_mixed_mortar_only_czm_contact_out"
    abs_zero = 1.0e-6
    map = false
  []
  [mortar_czm]
    type = Exodiff
    input = mortar_czm.i
    exodiff = mortar_czm_out.e
    requirement = 'The system shall be able to apply reproduce the setup of the interface cohesive '
                  'zone modeling with a mortar formulation.'
    map = false
  []
  [mortar_czm_analysis]
    type = Exodiff
    input = mortar_czm_analysis.i
    exodiff = mortar_czm_analysis_out.e
    requirement = 'The system shall be able to apply reproduce the setup of the interface cohesive '
                  'zone modeling with a mortar formulation and output analysis information to the '
                  'Exodus mesh.'
    map = false
  []
  [mortar_czm_friction]
    type = Exodiff
    input = cohesive_friction.i
    exodiff = cohesive_friction_out.e
    rel_err = 0.001
    abs_zero = 0.001
    requirement = 'The system shall be able to apply mortar frictional contact to the damaged interface.'
    map = false
  []
  [bilinear_mixed]
    type = CSVDiff
    input = bilinear_mixed.i
    csvdiff = bilinear_mixed_out.csv
    requirement = 'The system shall be able to apply a cohesive zone model based on interface '
                  'objects.'
    rel_err = 1.0e-5
    abs_zero = 0.001
    heavy = true
    capabilities = 'method=opt'
  []
  [bilinear_mixed_compare]
    type = CSVDiff
    input = bilinear_mixed_compare.i
    csvdiff = bilinear_mixed_compare_out.csv
    requirement = 'The system shall be able to apply a mortar cohesive zone model and yield results '
                  'similar to those of interface objects.'
    # This test compares different formulations
    rel_err = 0.035
    abs_zero = 0.001
    heavy = true
    capabilities = 'method=opt'
  []
  [traction_curve_modeI]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeI.i
    csvdiff = traction_curve_modeI_out.csv
    requirement = 'The system shall expose normal jump, cohesive traction, and energy dissipation '
                  'outputs for a monotonic mode-I mortar CZM loading path.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
    override_columns = 'jump_t traction_t'
    override_rel_err = '1.0e-6 1.0e-6'
    override_abs_zero = '1.0e-4 1.0e-4'
  []
  [traction_curve_modeI_dt_refined]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeI.i
    csvdiff = traction_curve_modeI_dt_refined_out.csv
    cli_args = 'Executioner/dt=0.005 Executioner/dtmin=0.005 '
               'Outputs/file_base=traction_curve_modeI_dt_refined_out'
    requirement = 'The system shall produce a reproducible mode-I mortar CZM response with a '
                  'refined time step.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
    override_columns = 'jump_t traction_t'
    override_rel_err = '1.0e-6 1.0e-6'
    override_abs_zero = '1.0e-4 1.0e-4'
  []
  [traction_curve_modeI_mesh_refined]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeI.i
    csvdiff = traction_curve_modeI_mesh_refined_out.csv
    cli_args = 'Mesh/base/nx=2 Mesh/top/nx=2 '
               'Outputs/file_base=traction_curve_modeI_mesh_refined_out'
    requirement = 'The system shall produce a reproducible mode-I mortar CZM response on a '
                  'refined interface mesh.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
    override_columns = 'jump_t traction_t'
    override_rel_err = '1.0e-6 1.0e-6'
    # Tangential noise in this refined pure mode-I case peaks at ~1.1e-4; 5e-4 covers
    # platform-dependent variation of that noise without masking large leakage growth.
    override_abs_zero = '5.0e-4 5.0e-4'
  []
  [traction_curve_modeI_severe_mismatch]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeI.i
    csvdiff = traction_curve_modeI_severe_mismatch_out.csv
    cli_args = 'Mesh/base/nx=5 '
               'Outputs/file_base=traction_curve_modeI_severe_mismatch_out'
    requirement = 'The system shall produce a reproducible mode-I mortar CZM response across a '
                  '5-to-1 non-matching mortar interface.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-8
    override_columns = 'jump_t traction_t'
    override_rel_err = '1.0e-5 1.0e-5'
    override_abs_zero = '1.0e-4 1.0e-4'
  []
  [traction_curve_modeII]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeII.i
    csvdiff = traction_curve_modeII_out.csv
    requirement = 'The system shall expose tangential jump and cohesive shear traction outputs for a '
                  'mode-II dominant mortar CZM loading path.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
    ignore_columns = 'mode_mixity'
    override_columns = 'jump_n traction_n'
    override_rel_err = '1.0e-6 1.0e-6'
    override_abs_zero = '1.0e-4 1.0e-4'
  []
  [traction_curve_mixed_power]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_mixed.i
    csvdiff = traction_curve_mixed_out.csv
    requirement = 'The system shall expose mixed-mode mortar CZM traction-separation response using '
                  'the POWER_LAW criterion.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
  []
  [traction_curve_mixed_bk]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_mixed.i
    csvdiff = traction_curve_mixed_bk_out.csv
    cli_args = 'UserObjects/czm_uo/mixed_mode_criterion=BK '
               'Outputs/file_base=traction_curve_mixed_bk_out'
    requirement = 'The system shall expose mixed-mode mortar CZM traction-separation response using '
                  'the BK criterion.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
  []
  [traction_cycle_modeI]
    type = CSVDiff
    issues = '#33045'
    input = traction_cycle_modeI.i
    csvdiff = traction_cycle_modeI_out.csv
    requirement = 'The system shall produce irreversible damage output during a mode-I mortar CZM '
                  'load-unload-reload cycle.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
  []
  [compression_shear_toggle_true]
    type = CSVDiff
    issues = '#33045'
    input = compression_shear_toggle.i
    csvdiff = compression_shear_toggle_out.csv
    requirement = 'The system shall suppress compressive cohesive normal traction under combined '
                  'compression and shear when set_compressive_traction_to_zero is true.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
  []
  [compression_shear_toggle_false]
    type = CSVDiff
    issues = '#33045'
    input = compression_shear_toggle.i
    csvdiff = compression_shear_toggle_nozero_out.csv
    cli_args = 'UserObjects/czm_uo/set_compressive_traction_to_zero=false '
               'Outputs/file_base=compression_shear_toggle_nozero_out'
    requirement = 'The system shall retain compressive cohesive normal traction under combined '
                  'compression and shear when set_compressive_traction_to_zero is false.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
  []
  [traction_curve_modeI_viscous]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeI_viscous.i
    csvdiff = traction_curve_modeI_viscous_out.csv
    requirement = 'The system shall expose a viscously regularized mode-I mortar CZM '
                  'traction-separation response.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
    restep = false
  []
  [mortar_czm_parallel]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeI.i
    csvdiff = traction_curve_modeI_parallel_out.csv
    cli_args = 'Outputs/file_base=traction_curve_modeI_parallel_out'
    min_parallel = 4
    max_parallel = 4
    requirement = 'The system shall reproduce the mode-I mortar CZM output on four MPI ranks.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-8
  []
  [traction_curve_modeI_3d]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeI_3d.i
    csvdiff = traction_curve_modeI_3d_out.csv
    requirement = 'The system shall expose normal traction and negligible tangential traction outputs '
                  'for a 3D mode-I mortar CZM loading path.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
    override_columns = 'traction_t1 traction_t2'
    override_rel_err = '1.0e-6 1.0e-6'
    override_abs_zero = '1.0e-4 1.0e-4'
  []
  [traction_curve_modeI_3d_inclined]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeI_3d_inclined.i
    csvdiff = traction_curve_modeI_3d_inclined_out.csv
    requirement = 'The system shall expose mortar CZM traction outputs on a 45-degree inclined 3D '
                  'mode-I interface.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
  []
  [traction_curve_modeIII_3d]
    type = CSVDiff
    issues = '#33045'
    input = traction_curve_modeIII_3d.i
    csvdiff = traction_curve_modeIII_3d_out.csv
    requirement = 'The system shall expose the second tangential cohesive traction component under '
                  'out-of-plane shear loading in 3D.'
    rel_err = 1.0e-6
    abs_zero = 1.0e-8
    override_columns = 'jump_n traction_n traction_t1'
    override_rel_err = '1.0e-6 1.0e-6 1.0e-6'
    override_abs_zero = '1.0e-4 1.0e-4 1.0e-4'
  []
  [robustness_brittle_interface]
    type = CSVDiff
    issues = '#33045'
    input = robustness_brittle_interface.i
    csvdiff = robustness_brittle_interface_out.csv
    requirement = 'The system shall produce a finite mode-I mortar CZM response when the softening '
                  'zone is nearly zero.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-8
  []
  [robustness_pure_shear_limit]
    type = CSVDiff
    issues = '#33045'
    input = robustness_pure_shear_limit.i
    csvdiff = robustness_pure_shear_limit_out.csv
    requirement = 'The system shall produce a finite dominant-shear mortar CZM response when normal '
                  'opening is near zero.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-8
  []
[]
