# An explanation and results for the full runs of these inputs files are given in the contact documentation

[Examples]
  design = 'Constraints/index.md'
  issues = '#13080 #23802'
  [frictionless-mortar-3d]
    type = 'Exodiff'
    input = 'frictionless-mortar-3d.i'
    exodiff = 'frictionless-mortar-3d_out.e'
    requirement = 'The system shall solve a 3D frictionless bouncing block problem with mortar '
                  'constraint'
    custom_cmp = 'frictionless-mortar-3d.cmp'
    capabilities = 'ad_size>=150 & method!=dbg'
    valgrind = 'none'
  []
  [frictionless-mortar-3d_pg]
    type = 'CSVDiff'
    input = 'frictionless-mortar-3d_pg.i'
    capabilities = 'ad_size>=150 & method!=dbg'
    csvdiff = 'frictionless-mortar-3d_pg_out.csv'
    requirement = 'The system shall solve a 3D frictionless bouncing block problem with mortar '
                  'constraint using Petrov-Galerkin approach.'
    valgrind = 'none'
  []
  [frictionless-mortar-3d-test-derivative-trimming]
    type = 'RunApp'
    input = 'frictionless-mortar-3d-test-derivative-trimming.i'
    requirement = 'The system shall solve a 3D frictionless bouncing block problem with mortar '
                  'constraints where the primary suface is composed of a single element and the '
                  'secondary side is composed of first order faces with a required derivative '
                  'container size of less than 50.'
  []
  [frictionless-mortar-3d-action]
    requirement = 'The system shall solve a 3D frictionless bouncing block problem with mortar '
                  'constraints using the contact action with'
    [first]
      type = 'CSVDiff'
      input = 'frictionless-mortar-3d-action.i'
      capabilities = 'ad_size>=150 & method!=dbg'
      csvdiff = 'frictionless-mortar-3d-action_out_contact-pressure_0002.csv'
      mesh_mode = 'REPLICATED' # see issue 24255
      detail = 'mortar quadrature designed to integrate linear polynomials on triangles'
      rel_err = 1.0e-5
      abs_zero = 1.0e-5
      valgrind = 'none'
    []
    [second]
      type = 'CSVDiff'
      input = 'frictionless-mortar-3d-action.i'
      capabilities = 'ad_size>=150 & method!=dbg'
      csvdiff = 'frictionless-mortar-3d-action-second_contact-pressure_0002.csv'
      mesh_mode = 'REPLICATED' # see issue 24255
      cli_args = 'Contact/mortar/segment_quadrature="fifth" Outputs/file_base=frictionless-mortar-3d-action-second'
      detail = 'mortar quadrature designed to integrate quadratic polynomials on triangles'
      rel_err = 1.0e-5
      abs_zero = 1.0e-5
      valgrind = 'none'
      prereq = 'frictionless-mortar-3d-action/first'
    []
  []
  [frictionless-mortar-3d-pg-action]
    prereq = 'frictionless-mortar-3d_pg'
    type = 'CSVDiff'
    input = 'frictionless-mortar-3d-action.i'
    cli_args = 'Contact/mortar/use_petrov_galerkin=true '
               'Outputs/file_base="frictionless-mortar-3d_pg_out" '
               'Postprocessors/active="contact lambda"'
    capabilities = 'ad_size>=100'
    csvdiff = 'frictionless-mortar-3d_pg_out.csv'
    requirement = 'The system shall solve a 3D frictionless bouncing block problem with mortar '
                  'constraint using Petrov-Galerkin approach in contact action.'
  []
  [frictionless-mortar-3d-action-correct-edge-dropping]
    type = 'CSVDiff'
    input = 'frictionless-mortar-3d-action.i'
    capabilities = 'ad_size>=150 & method!=dbg'
    csvdiff = 'frictionless-mortar-3d-action-correct-edge-dropping_out_contact-pressure_0002.csv'
    mesh_mode = 'REPLICATED' # see issue 24255
    requirement = 'The system shall solve a 3D frictionless bouncing block problem with mortar '
                  'constraint using the contact action and selecting the temporary flag correct edge '
                  'dropping.'
    cli_args = 'Contact/mortar/correct_edge_dropping=true '
               'Outputs/file_base=frictionless-mortar-3d-action-correct-edge-dropping_out'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
    valgrind = 'none'
  []
  [frictionless-mortar-3d-action-triangulation]
    requirement = 'The system shall support 3D mortar triangulation modes through the contact '
                  'action with debug-mesh output, using'
    [centroid-with-retessellation]
      type = 'RunApp'
      input = 'frictionless-mortar-3d-action.i'
      capabilities = 'ad_size>=150 & method!=dbg'
      cli_args = 'Contact/mortar/triangulation=centroid Contact/mortar/triangulate_triangles=true '
                 'Contact/mortar/debug_mesh=true Executioner/end_time=0.5 Executioner/dtmin=0.5 '
                 'Outputs/exodus=false Outputs/csv=false '
                 'Outputs/file_base=frictionless-mortar-3d-action-centroid-retess'
      mesh_mode = 'REPLICATED' # see issue 24255
      expect_out = 'mortar_segment\s+\|\s+256'
      detail = 'centroid-based triangulation that explicitly subdivides already-triangular '
               'clipped polygons when triangulate_triangles is enabled,'
      valgrind = 'none'
      prereq = 'frictionless-mortar-3d-action/first'
    []
    [centroid-no-retessellation]
      type = 'Exodiff'
      input = 'frictionless-mortar-3d-action.i'
      capabilities = 'ad_size>=150 & method!=dbg'
      cli_args = 'Contact/mortar/triangulation=centroid Contact/mortar/triangulate_triangles=false '
                 'Contact/mortar/debug_mesh=true Executioner/end_time=0.5 Executioner/dtmin=0.5 '
                 'Outputs/exodus=false Outputs/csv=false '
                 'Outputs/file_base=frictionless-mortar-3d-action-centroid-no-retess'
      mesh_mode = 'REPLICATED' # see issue 24255
      exodiff = 'frictionless-mortar-3d-action-centroid-no-retess_108_0_displaced_mortar_segment_mesh.e'
      detail = 'centroid-based triangulation that leaves already-triangular clipped polygons '
               'intact when triangulate_triangles is disabled,'
      valgrind = 'none'
      prereq = 'frictionless-mortar-3d-action-triangulation/centroid-with-retessellation'
    []
    [ear_clipping]
      type = 'RunApp'
      input = 'frictionless-mortar-3d-action.i'
      capabilities = 'ad_size>=150 & method!=dbg'
      cli_args = 'Contact/mortar/triangulation=ear_clipping Contact/mortar/debug_mesh=true '
                 'Executioner/end_time=0.5 Executioner/dtmin=0.5 '
                 'Outputs/exodus=false Outputs/csv=false '
                 'Outputs/file_base=frictionless-mortar-3d-action-ear-clipping'
      mesh_mode = 'REPLICATED' # see issue 24255
      expect_out = 'mortar_segment\s+\|\s+128'
      detail = 'an ear-clipping algorithm, and'
      valgrind = 'none'
      prereq = 'frictionless-mortar-3d-action/first'
    []
    [delaunay]
      type = 'RunApp'
      input = 'frictionless-mortar-3d-action.i'
      capabilities = 'ad_size>=150 & method!=dbg'
      cli_args = 'Contact/mortar/triangulation=delaunay Contact/mortar/debug_mesh=true '
                 'Executioner/end_time=0.5 Executioner/dtmin=0.5 '
                 'Outputs/exodus=false Outputs/csv=false '
                 'Outputs/file_base=frictionless-mortar-3d-action-delaunay'
      mesh_mode = 'REPLICATED' # see issue 24255
      expect_out = 'mortar_segment\s+\|\s+128'
      detail = 'a libMesh constrained-Delaunay backend that preserves polygon boundary edges.'
      valgrind = 'none'
      prereq = 'frictionless-mortar-3d-action/first'
    []
  []
  [frictionless-mortar-3d-debug-mesh]
    type = 'Exodiff'
    input = 'frictionless-mortar-3d.i'
    capabilities = 'ad_size>=150'
    exodiff = 'frictionless-mortar-3d_108_0_displaced_mortar_segment_mesh.e'
    cli_args = 'Executioner/end_time=0.5 Executioner/dtmin=0.5 Constraints/normal_lm/debug_mesh=true '
               'Constraints/normal_x/debug_mesh=true Constraints/normal_y/debug_mesh=true '
               'Constraints/normal_z/debug_mesh=true UserObjects/weighted_gap_uo/debug_mesh=true'
    requirement = 'The system shall solve a 3D frictionless bouncing block problem with mortar '
                  'constraint and output the mortar segment mesh for debugging purposes.'
    prereq = 'frictionless-mortar-3d'
  []
  [frictionless-mortar-3d-debug-mesh-triangulation]
    requirement = 'The system shall support 3D mortar triangulation modes for directly-specified '
                  'mortar objects (constraints + user-objects) with debug-mesh output, using'
    [centroid-with-retessellation]
      type = 'RunApp'
      input = 'frictionless-mortar-3d.i'
      capabilities = 'ad_size>=150'
      cli_args = 'Executioner/end_time=0.5 Executioner/dtmin=0.5 Outputs/exodus=false Outputs/csv=false '
                 'Outputs/file_base=frictionless-mortar-3d-direct-centroid-retess '
                 'Constraints/normal_lm/debug_mesh=true Constraints/normal_x/debug_mesh=true '
                 'Constraints/normal_y/debug_mesh=true Constraints/normal_z/debug_mesh=true '
                 'UserObjects/weighted_gap_uo/debug_mesh=true '
                 'Constraints/normal_lm/triangulation=centroid '
                 'Constraints/normal_x/triangulation=centroid '
                 'Constraints/normal_y/triangulation=centroid '
                 'Constraints/normal_z/triangulation=centroid '
                 'UserObjects/weighted_gap_uo/triangulation=centroid '
                 'Constraints/normal_lm/triangulate_triangles=true '
                 'Constraints/normal_x/triangulate_triangles=true '
                 'Constraints/normal_y/triangulate_triangles=true '
                 'Constraints/normal_z/triangulate_triangles=true '
                 'UserObjects/weighted_gap_uo/triangulate_triangles=true'
      expect_out = 'mortar_segment\s+\|\s+256'
      detail = 'centroid-based triangulation that explicitly subdivides already-triangular '
               'clipped polygons,'
      prereq = 'frictionless-mortar-3d-debug-mesh'
    []
    [centroid-no-retessellation]
      type = 'Exodiff'
      input = 'frictionless-mortar-3d.i'
      capabilities = 'ad_size>=150'
      cli_args = 'Executioner/end_time=0.5 Executioner/dtmin=0.5 Outputs/exodus=false Outputs/csv=false '
                 'Outputs/file_base=frictionless-mortar-3d-direct-centroid-no-retess '
                 'Constraints/normal_lm/debug_mesh=true Constraints/normal_x/debug_mesh=true '
                 'Constraints/normal_y/debug_mesh=true Constraints/normal_z/debug_mesh=true '
                 'UserObjects/weighted_gap_uo/debug_mesh=true '
                 'Constraints/normal_lm/triangulation=centroid '
                 'Constraints/normal_x/triangulation=centroid '
                 'Constraints/normal_y/triangulation=centroid '
                 'Constraints/normal_z/triangulation=centroid '
                 'UserObjects/weighted_gap_uo/triangulation=centroid '
                 'Constraints/normal_lm/triangulate_triangles=false '
                 'Constraints/normal_x/triangulate_triangles=false '
                 'Constraints/normal_y/triangulate_triangles=false '
                 'Constraints/normal_z/triangulate_triangles=false '
                 'UserObjects/weighted_gap_uo/triangulate_triangles=false'
      exodiff = 'frictionless-mortar-3d-direct-centroid-no-retess_108_0_displaced_mortar_segment_mesh.e'
      detail = 'centroid-based triangulation that leaves already-triangular clipped polygons '
               'intact,'
      prereq = 'frictionless-mortar-3d-debug-mesh-triangulation/centroid-with-retessellation'
    []
    [ear_clipping]
      type = 'RunApp'
      input = 'frictionless-mortar-3d.i'
      capabilities = 'ad_size>=150'
      cli_args = 'Executioner/end_time=0.5 Executioner/dtmin=0.5 Outputs/exodus=false Outputs/csv=false '
                 'Outputs/file_base=frictionless-mortar-3d-direct-ear-clipping '
                 'Constraints/normal_lm/debug_mesh=true Constraints/normal_x/debug_mesh=true '
                 'Constraints/normal_y/debug_mesh=true Constraints/normal_z/debug_mesh=true '
                 'UserObjects/weighted_gap_uo/debug_mesh=true '
                 'Constraints/normal_lm/triangulation=ear_clipping '
                 'Constraints/normal_x/triangulation=ear_clipping '
                 'Constraints/normal_y/triangulation=ear_clipping '
                 'Constraints/normal_z/triangulation=ear_clipping '
                 'UserObjects/weighted_gap_uo/triangulation=ear_clipping'
      expect_out = 'mortar_segment\s+\|\s+128'
      detail = 'an ear-clipping algorithm, and'
      prereq = 'frictionless-mortar-3d-debug-mesh'
    []
    [delaunay]
      type = 'RunApp'
      input = 'frictionless-mortar-3d.i'
      capabilities = 'ad_size>=150'
      cli_args = 'Executioner/end_time=0.5 Executioner/dtmin=0.5 Outputs/exodus=false Outputs/csv=false '
                 'Outputs/file_base=frictionless-mortar-3d-direct-delaunay '
                 'Constraints/normal_lm/debug_mesh=true Constraints/normal_x/debug_mesh=true '
                 'Constraints/normal_y/debug_mesh=true Constraints/normal_z/debug_mesh=true '
                 'UserObjects/weighted_gap_uo/debug_mesh=true '
                 'Constraints/normal_lm/triangulation=delaunay '
                 'Constraints/normal_x/triangulation=delaunay '
                 'Constraints/normal_y/triangulation=delaunay '
                 'Constraints/normal_z/triangulation=delaunay '
                 'UserObjects/weighted_gap_uo/triangulation=delaunay'
      expect_out = 'mortar_segment\s+\|\s+128'
      detail = 'a libMesh constrained-Delaunay backend that preserves polygon boundary edges.'
      prereq = 'frictionless-mortar-3d-debug-mesh'
    []
  []
  [frictional-mortar-3d]
    type = 'Exodiff'
    input = 'frictional-mortar-3d.i'
    capabilities = 'ad_size>=150 & method!=dbg'
    exodiff = 'frictional-mortar-3d_out.e'
    requirement = 'The system shall solve a 3D frictional bouncing block problem with mortar '
                  'constraint using nodal-attached geometry.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
    valgrind = 'none'
  []
  [frictional-mortar-3d-pg]
    type = 'CSVDiff'
    input = 'frictional-mortar-3d_pg.i'
    capabilities = 'ad_size>=150 & method!=dbg'
    csvdiff = 'frictional-mortar-3d_pg_out_contact-pressure_0001.csv '
              'frictional-mortar-3d_pg_out_frictional-pressure-3d_0001.csv '
              'frictional-mortar-3d_pg_out_frictional-pressure_0001.csv'
    requirement = 'The system shall solve a 3D frictional bouncing block problem with mortar '
                  'constraint using the Petrov-Galerkin approach.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
    valgrind = 'none'
  []
  [frictional-mortar-3d-function]
    type = 'Exodiff'
    input = 'frictional-mortar-3d-function.i'
    capabilities = 'ad_size>=150 & method!=dbg'
    exodiff = 'frictional-mortar-3d-function_out.e'
    requirement = 'The system shall solve a 3D frictional block problem with mortar constraint using '
                  'a simple frictional model dependent on relative velocity and contact pressure.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
    valgrind = 'none'
  []
  [frictional-mortar-3d-action]
    type = 'CSVDiff'
    input = 'frictional-mortar-3d-action.i'
    capabilities = 'ad_size>=150 & method!=dbg'
    csvdiff = 'frictional-mortar-3d-action_out_frictional-pressure_0001.csv '
              'frictional-mortar-3d-action_out_frictional-pressure-3d_0001.csv '
              'frictional-mortar-3d-action_out_tangent_x_0001.csv '
              'frictional-mortar-3d-action_out_tangent_y_0001.csv'
    requirement = 'The system shall solve a 3D frictional bouncing block problem with mortar '
                  'constraints using nodal-attached geometry and a frictional pressure vector '
                  'generated by an auxiliary kernel through a user-friendly action. Results are '
                  'diffed against non-action output.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
    valgrind = 'none'
  []
  [frictional-mortar-3d-pg-action]
    prereq = 'frictional-mortar-3d-pg'
    type = 'CSVDiff'
    input = 'frictional-mortar-3d-action.i'
    cli_args = 'Contact/mortar/use_petrov_galerkin=true '
               'Outputs/file_base=frictional-mortar-3d_pg_out'
    capabilities = 'ad_size>=150'
    csvdiff = 'frictional-mortar-3d_pg_out_contact-pressure_0001.csv '
              'frictional-mortar-3d_pg_out_frictional-pressure-3d_0001.csv '
              'frictional-mortar-3d_pg_out_frictional-pressure_0001.csv'
    requirement = 'The system shall solve a 3D frictional bouncing block problem with mortar '
                  'constraint using the Petrov-Galerkin approach in contact action.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
  []
  [half_sphere_nodal_geometry]
    type = 'Exodiff'
    exodiff = 'nodal_geometry_only.e'
    input = 'half_sphere_nodal_geometry.i'
    capabilities = 'ad_size>=100'
    valgrind = 'heavy'
    requirement = 'The system shall generate consistent mortar nodal geometry (normal and tangent '
                  'vectors) on a spherical surface.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
    allow_warnings = true
    max_parallel = 1
    restep = false # Issue #31054
    # not running any time step, just examining nodal geometry
    recover = false
  []
  [frictional-mortar-3d-penalty]
    type = 'Exodiff'
    input = 'frictional-mortar-3d-penalty.i'
    capabilities = 'ad_size>=200'
    exodiff = 'frictional-mortar-3d-penalty_out.e'
    restep = false # Issue #31054
    requirement = 'The system shall solve a 3D frictional problem with mortar constraint using a '
                  'penalty approach'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
  []
  [frictionless-mortar-3d-penalty]
    type = 'Exodiff'
    input = 'frictionless-mortar-3d-penalty.i'
    capabilities = 'ad_size>=200'
    exodiff = 'frictionless-mortar-3d-penalty_out.e'
    requirement = 'The system shall solve a 3D frictionless problem with mortar constraint using a '
                  'penalty approach'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
  []
  [frictional-mortar-3d-al]
    type = 'Exodiff'
    input = 'frictional-mortar-3d-al.i'
    exodiff = 'frictional-mortar-3d-al_out.e'
    requirement = 'The system shall be able to solve a 3D frictional problem with mortar constraint using a '
                  'augmented Lagrange approach and converging to prescribed tolerance.'
    rel_err = 1.0e-5
    abs_zero = 1.0e-5
    valgrind = none
    capabilities = 'ad_size>=200 & method=opt'
    heavy = true
    max_time = 1000
  []
[]
