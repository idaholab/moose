[Tests]
  [rotation]
    design = 'ControlDrumMaterial.md'
    requirement = 'The system shall compute material properties in heterogeneous control drums'
    issues = '#32765'

    [2d_z]
      type = 'Exodiff'
      input = '2d_z_rotation.i'
      exodiff = '2d_z_rotation_out.e'
      detail = 'rotating around +z axis'
    []

    [2d_z_var]
      type = 'Exodiff'
      input = '2d_z_var_rotation.i'
      exodiff = '2d_z_var_rotation_out.e'
