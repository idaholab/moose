    requirement = 'The system shall preserve the one-dimensional porous baffle Bernoulli pressure jump and the non-oscillatory superficial velocity profile using the linear finite volume SIMPLE solve.'
    design = 'SIMPLE.md PorousRhieChowMassFlux.md LinearFVMomentumFriction.md'
    cli_args = 'Outputs/exodus=false Outputs/console=false UserObjects/rc/debug_baffle=false LinearFVKernels/p_diffusion/debug_baffle_jump=false'
    recover = false
    max_threads = 1
    allow_warnings = true
  []

