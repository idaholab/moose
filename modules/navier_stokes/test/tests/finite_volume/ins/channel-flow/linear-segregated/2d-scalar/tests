[Tests]
  issues = '#28819'
  design = 'SIMPLE.md LinearFVScalarAdvection.md'
  [channel]
    requirement = "The system shall be able to solve a scalar advection problem,"
    [simple]
      type = 'Exodiff'
      input = channel.i
      exodiff = 'channel_out.e'
      recover = false # we don't support recovery for SIMPLE yet
      max_threads = 1 # see libmesh issue #3808
      detail = "using the kernel-based syntax,"
    []
    [simple_vanleer_scalar_advection]
      type = 'Exodiff'
      input = channel.i
      cli_args = 'scalar_advected_interp_method=vanLeer'
      exodiff = 'channel_out.e'
      prereq = 'channel/simple'
      recover = false # we don't support recovery for SIMPLE yet
      max_threads = 1 # see libmesh issue #3808
      detail = "using the kernel-based syntax with a van Leer scalar advection interpolation,"
    []
    [physics]
      type = 'Exodiff'
      input = channel-physics.i
      exodiff = 'channel-physics_out.e'
      recover = false # we don't support recovery for SIMPLE yet
      max_threads = 1 # see libmesh issue #3808
      detail = "using the shorthand Physics syntax."
    []
    [physics_minmod_scalar_advection]
      type = 'Exodiff'
      input = channel-physics.i
      cli_args = 'scalar_advected_interp_method=min_mod'
      exodiff = 'channel-physics_out.e'
      prereq = 'channel/physics'
      recover = false # we don't support recovery for SIMPLE yet
      max_threads = 1 # see libmesh issue #3808
      detail = "using the shorthand Physics syntax with a minmod scalar advection interpolation."
    []
  []
[]
