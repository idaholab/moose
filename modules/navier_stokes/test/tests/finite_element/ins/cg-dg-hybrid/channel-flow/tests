[Tests]
  design = 'modules/navier_stokes/index.md'
  issues = '#24055'
  [hybrid-channel]
    type = Exodiff
    input = channel-hybrid.i
    exodiff = channel-hybrid_out.e
    requirement = 'The system shall be able to solve a channel flow problem using a hybrid CG-DG discretization with first Lagrange pressure and first monomial velocity.'
    capabilities = 'method!=dbg'
    valgrind = 'none'
    min_parallel = 2 # more ranks due to memory usage
    # Raised for the lagrange multiplier diffing right above the default tolerance
    abs_zero = 2e-10
  []
  [tri_mass_conservation]
    type = CSVDiff
    input = by-parts-channel-hybrid.i
    csvdiff = by-parts-channel-hybrid_out.csv
    requirement = 'The system shall demonstrate mass conservation using a hybrid CG-DG discretization with first Lagrange pressure and first monomial velocity on triangular elements.'
  []
[]
