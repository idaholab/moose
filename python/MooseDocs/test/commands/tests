    type = PythonUnitTest
    input = test_check.py
    min_slots = 2 # uses threads

    requirement = "The system shall include a utility for reporting the status of software quality items."
    collections = "FAILURE_ANALYSIS"
  []
  [generate]
    type = PythonUnitTest
    input = test_generate.py
    min_slots = 2 # uses threads
    issues = '#16155'

