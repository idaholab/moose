{#- Required jinja arguments                                                                  -#}
{#- APPTAINER_BOOTSTRAP: The BootStrap to use (typically localimage or oras)                  -#}
{#- APPTAINER_FROM: The From to use (path to an image or an oras URI)                         -#}
{#- MOOSE_DIR: Path on the host to the MOOSE repository                                       -#}
{#- NEML2_GIT_SHA: The git SHA to use for neml2                                               -#}
{#- NEML2_GIT_REMOTE: The git remote to use to get neml2                                      -#}
{#- WASP_GIT_SHA: The git SHA to use for WASP                                                 -#}
{#- WASP_GIT_REMOTE: The git remote to use to get WASP                                        -#}

{#- Optional jinja arguments                                                                  -#}
{#- CONDUIT_GIT_SHA: The git SHA to use for conduit                                           -#}
{#- CONDUIT_GIT_REMOTE: The git remote to use to get conduit                                  -#}
{#- CONDUIT_OPTIONS: Options to pass to conduit build                                         -#}
{#- MFEM_GIT_SHA: The git SHA to use for MFEM                                                 -#}
{#- MFEM_GIT_REMOTE: The git remote to use to get MFEM                                        -#}
{#- MFEM_OPTIONS: Options to pass to mfem build                                               -#}
{#- MOOSE_JOBS: Number of jobs to pass to the builds                                          -#}
{#- OPTFLAGS: Optimization flags to set when building                                         -#}
{#- PROFILING: Set to anything to build for profiling (add gperftools)                        -#}
{#- PYTORCH_GIT_SHA: The git SHA to use for pytorch                                           -#}
{#- PYTORCH_GIT_REMOTE: The git remote to use to get pytorch                                  -#}
{#- SKIP_FINGERPRINTS: Set to skip fingerprint verification                                   -#}
{#- WITH_MFEM: Whether or not to build mfem (default: 1 to build, 0 to not build)             -#}
{#- WITH_FMU: Whether or not to install python fmu utilities (default: false)                 -#}
{#- WITHOUT_PYTORCH: Set to anything to not build/download pytorch and neml2                  -#}

{#- Set WITH_MFEM default if not set                                                          -#}
{%- if WITH_MFEM is not defined %}
{%- set WITH_MFEM = '1' %}
{%- endif %}

{#- The within-container build directory to use                                               -#}
{%- set ROOT_BUILD_DIR = '/root/build' -%}

{#- The installation location for gperftools                                                  -#}
{%- set GPERF_DIR = '/opt/gperftools' -%}
{#- The installation location for pprof                                                       -#}
{%- set PPROF_DIR = '/opt/pprof' -%}
{#- The installation location for libtorch                                                    -#}
{%- set LIBTORCH_DIR = '/opt/libtorch' -%}
{#- The script used to install conduit                                                        -#}
{%- set CONDUIT_BUILD_SCRIPT = 'update_and_rebuild_conduit.sh' -%}
{#- The installation location for conduit                                                     -#}
{%- set CONDUIT_DIR = '/opt/conduit' -%}
{#- The script used to install mfem                                                           -#}
{%- set MFEM_BUILD_SCRIPT = 'update_and_rebuild_mfem.sh' -%}
{#- The installation location for mfem                                                        -#}
{%- set MFEM_DIR = '/opt/mfem' -%}
{#- The script used to install wasp                                                           -#}
{%- set WASP_BUILD_SCRIPT = 'update_and_rebuild_wasp.sh' -%}
{#- The installation location for wasp                                                        -#}
{%- set WASP_DIR = '/opt/wasp' -%}
{#- The script used to install neml2                                                          -#}
{%- set NEML2_BUILD_SCRIPT = 'update_and_rebuild_neml2.sh' -%}
{#- The installation location for neml2                                                       -#}
{%- set NEML2_DIR = '/opt/neml2' -%}
{#- The installation location for uv                                                          -#}
{%- set UV_DIR = '/opt/uv' -%}
{#- The installation location for python                                                      -#}
{%- set PYTHON_DIR = '/opt/python' -%}
{#- The installation location for code-server                                                 -#}
{%- set CODE_SERVER_DIR = '/opt/code-server' -%}

{#- The files directory for this definition                                                   -#}
{%- set FILES_DIR = MOOSE_DIR + '/apptainer/files/moose-dev' -%}

BootStrap: {{ APPTAINER_BOOTSTRAP }}
From: {{ APPTAINER_FROM }}
{%- if SKIP_FINGERPRINTS is not defined %}
# MOOSE-NCRC key
Fingerprints: 0CFFCAB55E806363601C442D211817B01E0911DB
{%- endif %}

%environment
    test -d {{ PYTHON_DIR }} && export PATH={{ PYTHON_DIR }}/bin:${PATH}
    test -d {{ CODE_SERVER_DIR }} && export PATH={{ CODE_SERVER_DIR }}/bin:${PATH}

    export WASP_DIR={{ WASP_DIR }}
    export PATH=${WASP_DIR}/bin:$PATH

{%- if WITH_MFEM %}
    test -d {{ CONDUIT_DIR }} && export CONDUIT_DIR={{ CONDUIT_DIR }}
    test -d {{ MFEM_DIR }} && export MFEM_DIR={{ MFEM_DIR }}
{%- endif %}

{% if WITHOUT_PYTORCH is not defined %}
    test -d {{ LIBTORCH_DIR }} && export LIBTORCH_DIR={{ LIBTORCH_DIR }}
    test -d {{ NEML2_DIR }} && export NEML2_DIR={{ NEML2_DIR }}
{%- endif %}

{% if PROFILING is defined %}
    # For profiling
    export GPERF_DIR={{ GPERF_DIR }}
    export PATH={{ PPROF_DIR }}/bin:$PATH
    export METHOD=oprof
{%- endif %}

%post -c /bin/bash
    set -uexo pipefail

    source /.singularity.d/os_functions.sh
    update_system_packages

    ROOT_BUILD_DIR={{ ROOT_BUILD_DIR }}
    export MOOSE_JOBS={{ MOOSE_JOBS }}

    # Individual versions for packages to install, in the order
    # in which they are installed below.
    # code-server and code-server plugins
    CODE_SERVER_VERSION=4.128.0
    MOOSE_LANGUAGE_SUPPORT_VERSION=1.5.2
    # python
    PYTHON_VERSION=3.14.6
{% if WITH_FMU %}
    # PyFMI python package and its dependencies
    FMI_LIBRARY_VERSION=3.0.4
    ASSIMULO_VERSION=3.8.0
    PYFMI_VERSION=2.21.0
    # PythonFMU python package
    PYTHONFMU_VERSION=0.7.0
{%- endif %}
{% if PROFILING is defined %}
    # pprof and its dependencies
    GPERFTOOLS_VERSION=2.18.1
    GO_VERSION=1.26.1
    PPROF_SHA=a0b0bb1d4134f37be44de6c328680339b0fc13ad
{%- endif %}

    # Optimization flags
{%- if OPTFLAGS is not defined %}
    OPTFLAGS=("-march=x86-64-v3" "-mtune=generic")
{%- else %}
    IFS=' ' read -r -a OPTFLAGS <<< "{{ OPTFLAGS }}"
{%- endif %}

    # Special setup for OpenMPI
    if [ -n "${MOOSE_OPENMPI_DIR:-}" ]; then
        # MFEM (and maybe other things?) use mpirun. In the case of openmpi,
        # we need to have a clean tmpdir for it to store state (which,
        # for some reason, /tmp doesn't work for this in fakeroot?)
        export TMPDIR=${ROOT_BUILD_DIR}/tmpdir
        mkdir $TMPDIR
    # Special setup for MPICH
    elif [ -n "${MOOSE_MPICH_DIR:-}" ]; then
        # Required at configure time for MFEM checking petsc
        export MPIR_CVAR_ENABLE_GPU=0

        # When using mpich with hwloc, install hwloc-gui to
        # get "lstopo-no-graphics", which can be used to
        # prebuild a topology file to avoid hwloc reading
        # topology for every run
        (
            if [ -n "${CUDA_DIR:-}" ]; then
                export LD_LIBRARY_PATH=${CUDA_DIR}/compat:${LD_LIBRARY_PATH:-}
            fi
            if mpiexec --version | grep -q hwloc; then
                if is_rocky; then
                    dnf install -y hwloc-gui
                elif is_ubuntu; then
                    apt-get install -y --no-install-recommends hwloc-nox
                fi
            fi
        )
    fi

    # Reset compiler variables to those from MPI to the underlying
    # compilers because the first packages we build here don't
    # and shouldn't be linked to MPI
    for var in CC CXX FC F90 F77; do
        before_var="${var}_BEFORE"
        declare "${before_var}=${!var}"
        export "$var="$("${!var}" -show | awk '{print $1}')""
        echo "Changed ${var} from ${!before_var} to ${!var}"
    done

    # Install code-server
    (
        cd ${ROOT_BUILD_DIR}

        CODE_SERVER_DIR={{ CODE_SERVER_DIR }}

        # Install code-server
        if is_rocky; then
            CODE_SERVER_FILE=code-server-${CODE_SERVER_VERSION}-amd64.rpm
            curl -fOL https://github.com/coder/code-server/releases/download/v${CODE_SERVER_VERSION}/${CODE_SERVER_FILE}
            rpm -i ${CODE_SERVER_FILE}
            rm ${CODE_SERVER_FILE}
        elif is_ubuntu; then
            CODE_SERVER_FILE=code-server_${CODE_SERVER_VERSION}_amd64.deb
            curl -fOL https://github.com/coder/code-server/releases/download/v${CODE_SERVER_VERSION}/${CODE_SERVER_FILE}
            apt install ./${CODE_SERVER_FILE}
            rm ${CODE_SERVER_FILE}
        fi

        # Setup directory for code-server extensions. The extensions folder can be
        # filled by other applications as they wish to have extensions auto installed
        # by the "setup-code-server-extensions" script (in PATH)
        mkdir ${CODE_SERVER_DIR}/extensions

        # Download extensions for code-server, currently just moose language support
        cd ${CODE_SERVER_DIR}/extensions
        curl -L -O https://github.com/idaholab/moose-language-support/releases/download/v${MOOSE_LANGUAGE_SUPPORT_VERSION}/moose-language-support-${MOOSE_LANGUAGE_SUPPORT_VERSION}.vsix

        # Setup permissions for the code server extras
        find ${CODE_SERVER_DIR} -type d -exec chmod 755 {} +
        chmod 755 ${CODE_SERVER_DIR}/bin/*
        chmod 644 ${CODE_SERVER_DIR}/extensions/*
    )

    # Build and install wasp
    (
        cd ${ROOT_BUILD_DIR}

        # Clone wasp
        WASP_SRC_DIR=${ROOT_BUILD_DIR}/wasp
        git clone --depth 1 {{ WASP_GIT_REMOTE }} ${WASP_SRC_DIR}
        cd ${WASP_SRC_DIR}
        git fetch --depth 1 origin {{ WASP_GIT_SHA }}
        git checkout {{ WASP_GIT_SHA }}
        git submodule update --init --recursive

        # Build wasp
        WASP_DIR={{ WASP_DIR }}
        WASP_LOGS=${WASP_DIR}/logs
        mkdir -p ${WASP_LOGS}
        WASP_SRC_DIR=${WASP_SRC_DIR} \
            ${ROOT_BUILD_DIR}/{{ WASP_BUILD_SCRIPT }} \
                -DCMAKE_CXX_FLAGS="${OPTFLAGS[*]}" \
                -DCMAKE_INSTALL_PREFIX:STRING=${WASP_DIR} 2>&1 | tee ${WASP_LOGS}/build.log

        # Cleanup
        rm -rf ${WASP_SRC_DIR} ${ROOT_BUILD_DIR}/{{ WASP_BUILD_SCRIPT }}
    )

    # Install python environment
    PYTHON_DIR={{ PYTHON_DIR }}
    (
        cd ${ROOT_BUILD_DIR}

        UV_DIR={{ UV_DIR }}

        # Install uv
        UV_BIN_DIR=${UV_DIR}/bin
        XDG_DATA_HOME=${UV_DIR}/data
        mkdir -p ${UV_BIN_DIR} ${XDG_DATA_HOME}
        curl -LsSf https://astral.sh/uv/install.sh | XDG_DATA_HOME=${XDG_DATA_HOME} XDG_BIN_HOME=${UV_BIN_DIR} sh

        # Use uv to create a python venv and verify the version
        XDG_DATA_HOME=${XDG_DATA_HOME} ${UV_BIN_DIR}/uv venv ${PYTHON_DIR} --no-project --no-config --relocatable --no-cache --python "$PYTHON_VERSION"

        # Setup python development environment from uv environment
        UV_PYTHON_DIR="$(realpath "$(dirname "$(realpath "${PYTHON_DIR}/bin/python${PYTHON_VERSION%.*}")")/..")"
        ln -s "${UV_PYTHON_DIR}/bin/python3-config" "${PYTHON_DIR}/bin/"
        ln -s "${UV_PYTHON_DIR}/bin/python${PYTHON_VERSION%.*}-config" "${PYTHON_DIR}/bin/"
        ln -s "${UV_PYTHON_DIR}/include" "${PYTHON_DIR}/"

        # Setup helper script for running [pip, pip3]
        cat <<EOF > "${PYTHON_DIR}/bin/pip"
#!/bin/bash
# Wrapper script that forwards pip commands to uv
#
# Derived containers should be able to run "pip install ..."
# to install additional python packages
export XDG_DATA_HOME=${XDG_DATA_HOME}
export UV_PYTHON=${PYTHON_DIR}
export UV_NO_CACHE=1
export UV_LINK_MODE=copy
${UV_BIN_DIR}/uv pip "\$@"
EOF
        chmod +x "${PYTHON_DIR}/bin/pip"
        ln -s "${PYTHON_DIR}/bin/pip" "${PYTHON_DIR}/bin/pip3"

        # Install the MOOSE requirements
        ${PYTHON_DIR}/bin/pip install -r /root/requirements.txt && rm /root/requirements.txt
    )

{% if WITH_FMU %}
    # Install fmi-library dependency for pyfmi
    FMI_LIBRARY_DIR=/opt/fmi-library
    (
        cd ${ROOT_BUILD_DIR}

        # Clone fmi-library
        FMI_LIBRARY_SRC_DIR=${ROOT_BUILD_DIR}/fmi-library
        git clone --branch ${FMI_LIBRARY_VERSION} \
            --single-branch \
            https://github.com/modelon-community/fmi-library.git ${FMI_LIBRARY_SRC_DIR}
        cd ${FMI_LIBRARY_SRC_DIR}

        # Build and install fmi-library
        mkdir build_tmp && cd build_tmp
        cmake .. \
            -DCMAKE_BUILD_TYPE=Release \
            -DCMAKE_INSTALL_PREFIX="$FMI_LIBRARY_DIR" \
            -GNinja \
            -DFMILIB_BUILD_SHARED_LIB=ON \
            -DFMILIB_BUILD_TESTS=OFF
        cmake --build . --parallel ${MOOSE_JOBS}
        cmake --install . --prefix ${FMI_LIBRARY_DIR}

        # Cleanup
        rm -rf ${FMI_LIBRARY_SRC_DIR}
    )

    # Install cython for the assimulo setup.py installs that follow
    # (assimulo and pyfmi). After that, we can delete it (if it
    # isn't already installed).
    FMU_REMOVE_CYTHON=
    ${PYTHON_DIR}/bin/pip show cython &>/dev/null || (${PYTHON_DIR}/bin/pip install cython && FMU_REMOVE_CYTHON=1)

    # Install assimulo dependency for pyfmi
    (
        cd ${ROOT_BUILD_DIR}

        # Clone Assimulo
        ASSIMULO_SRC_DIR=${ROOT_BUILD_DIR}/Assimulo
        git clone --branch "Assimulo-${ASSIMULO_VERSION}" \
            --single-branch \
            https://github.com/modelon-community/Assimulo.git ${ASSIMULO_SRC_DIR}
        cd ${ASSIMULO_SRC_DIR}

        export PATH={{ PYTHON_DIR }}/bin:${PATH}

        # Build Assimulo
        python setup.py install

        # Cleanup
        rm -rf ${ASSIMULO_SRC_DIR}

        # Test package
        python -c "import assimulo; print('Assimulo:', assimulo.__version__)"
    )

    # Install PyFMI
    (
        cd ${ROOT_BUILD_DIR}

        # Clone pyfmi
        PYFMI_SRC_DIR=${ROOT_BUILD_DIR}/PyFMI
        git clone --branch "PyFMI-${PYFMI_VERSION}" \
            --single-branch \
            https://github.com/modelon-community/PyFMI.git ${PYFMI_SRC_DIR}
        cd ${PYFMI_SRC_DIR}

        export PATH={{ PYTHON_DIR }}/bin:${PATH}

        # Setup pyfmi
        python setup.py install --fmil-home=${FMI_LIBRARY_DIR}

        # Cleanup
        rm -rf ${PYFMI_SRC_DIR}

        # Test package
        python -c "import pyfmi; print('PyFMI:', pyfmi.__version__)"
    )

    # Remove cython if we installed it
    test -z "$FMU_REMOVE_CYTHON" || ${PYTHON_DIR}/bin/pip uninstall -y cython
    FMU_REMOVE_CYTHON=

    # Install PythonFMU
    (
        cd ${ROOT_BUILD_DIR}

        # Clone PythonFMU
        PYTHONFMU_SRC_DIR=${ROOT_BUILD_DIR}/PythonFMU
        git clone --branch v${PYTHONFMU_VERSION} --single-branch \
            https://github.com/NTNU-IHB/PythonFMU.git ${PYTHONFMU_SRC_DIR}
        cd ${PYTHONFMU_SRC_DIR}

        export PATH={{ PYTHON_DIR }}/bin:${PATH}

        # Build pythonfmu
        mkdir build
        cd build
        cmake .. -DCMAKE_BUILD_TYPE=Release
        cmake --build . --parallel ${MOOSE_JOBS}
        cd ..

        # Install pythonfmu
        pip install .

        # Cleanup
        rm -rf ${PYTHONFMU_SRC_DIR}

        # Test package
        python -c "import pythonfmu; print('PythonFMU:', pythonfmu.__version__)"
    )
{%- endif %}

{% if WITHOUT_PYTORCH is not defined %}
    # Build libtorch
    (
        cd ${ROOT_BUILD_DIR}

        # Clone pytorch
        PYTORCH_SRC_DIR=${ROOT_BUILD_DIR}/pytorch
        git clone --depth 1 {{ PYTORCH_GIT_REMOTE }} ${PYTORCH_SRC_DIR}
        cd ${PYTORCH_SRC_DIR}
        git fetch --depth 1 origin {{ PYTORCH_GIT_SHA }}
        git checkout {{ PYTORCH_GIT_SHA }}
        git submodule update --init --depth 1 --recursive

        # Create a temporary python environment for building libtorch
        LIBTORCH_BUILD_VENV=${ROOT_BUILD_DIR}/pytorch_venv
        ${PYTHON_DIR}/bin/python -m venv ${LIBTORCH_BUILD_VENV}
        source ${LIBTORCH_BUILD_VENV}/bin/activate
        pip3 install --no-cache -r ${PYTORCH_SRC_DIR}/requirements.txt

        # Determine additional libtorch configure flags
        LIBTORCH_FLAGS=()
        # Require CUDA if we have cuda available
        if [ -n "${CUDA_DIR:-}" ]; then
            # 8.0 A100 (hoodoo), 8.6 A2 (milangpubuild), 8.9 L4 (rod, cone)
            LIBTORCH_FLAGS+=(
                "-DTORCH_CUDA_ARCH_LIST=8.0;8.6;8.9"
                "-DUSE_CUDA:BOOL=ON"
                "-DCUDA_TOOLKIT_ROOT_DIR=${CUDA_DIR}"
            )
        else
            LIBTORCH_FLAGS+=("-DUSE_CUDA:BOOL=OFF")
        fi

        # Build and install libtorch
        LIBTORCH_DIR={{ LIBTORCH_DIR }}
        LIBTORCH_LOGS=$LIBTORCH_DIR/logs
        mkdir -p $LIBTORCH_LOGS
        LIBTORCH_BUILD_DIR=${ROOT_BUILD_DIR}/libtorch_build
        mkdir $LIBTORCH_BUILD_DIR
        source ${ROOT_BUILD_DIR}/configure_libtorch.sh
        configure_libtorch \
            "$PYTORCH_SRC_DIR" \
            "$LIBTORCH_BUILD_DIR" \
            "$LIBTORCH_DIR" \
            -DCMAKE_C_FLAGS="-w ${OPTFLAGS[*]}" \
            -DCMAKE_CXX_FLAGS="-w ${OPTFLAGS[*]}" \
            "${LIBTORCH_FLAGS[@]}" 2>&1 | tee ${LIBTORCH_LOGS}/cmake.log
        build_libtorch "$LIBTORCH_BUILD_DIR" "$MOOSE_JOBS" 2>&1 | tee ${LIBTORCH_LOGS}/build.log
        install_libtorch "$LIBTORCH_BUILD_DIR" "$LIBTORCH_DIR" 2>&1 | tee ${LIBTORCH_LOGS}/install.log

        # Cleanup the build environment
        deactivate
        rm -rf ${LIBTORCH_BUILD_VENV} ${PYTORCH_SRC_DIR} ${LIBTORCH_BUILD_DIR}
    )
{%- endif %}

{% if PROFILING is defined %}
    # Install gperftools
    (
        cd ${ROOT_BUILD_DIR}

        # Clone gperftools
        GPERFTOOLS_SRC=${ROOT_BUILD_DIR}/gperftools
        git clone -b gperftools-${GPERFTOOLS_VERSION} --single-branch \
            https://github.com/gperftools/gperftools.git ${GPERFTOOLS_SRC}
        cd ${GPERFTOOLS_SRC}

        # Build gperftools
        GPERF_DIR={{ GPERF_DIR }}
        ./autogen.sh
        ./configure --prefix=${GPERF_DIR} --enable-frame-pointers
        make -j ${MOOSE_JOBS}
        make install

        # Cleanup
        rm -rf ${GPERFTOOLS_SRC}
    )

    # Install pprof
    (
        # Install go for building pprof; to be removed
        GO_TAR=${ROOT_BUILD_DIR}/go.tar.gz
        curl -L https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz -o ${GO_TAR}
        tar -C ${ROOT_BUILD_DIR} -xf ${GO_TAR}
        rm ${GO_TAR}
        export PATH=${ROOT_BUILD_DIR}/go/bin:${PATH}
        export GOPATH=${ROOT_BUILD_DIR}/gopath
        mkdir ${GOPATH}

        # Install pprof
        PPROF_DIR={{ PPROF_DIR }}
        GOBIN=${PPROF_DIR}/bin go install github.com/google/pprof@${PPROF_SHA}

        # Remove go now that pprof is installed
        go clean -cache -modcache
        rm -rf ${GOPATH} ${ROOT_BUILD_DIR}/go
    )
{%- endif %}

    # Use the MPI compiler wrappers again
    for var in CC CXX FC F90 F77; do
        BEFORE_VAR="${var}_BEFORE"
        echo "Resetting ${var} from ${!var} to ${!BEFORE_VAR}"
        export "${var}=${!BEFORE_VAR}"
    done

    # Expose the compat libraries with mpich and cuda (which build scripts
    # will use to test if the compiler works)
    if [ -n "${CUDA_DIR:-}" ] && [ -n "${MOOSE_MPICH_DIR:-}" ]; then
        export LD_LIBRARY_PATH=${CUDA_DIR}/compat:${LD_LIBRARY_PATH:-}
    fi

{% if WITHOUT_PYTORCH is not defined %}
    # Build neml2
    (
        cd ${ROOT_BUILD_DIR}

        NEML2_DIR={{ NEML2_DIR }}
        NEML2_BUILD_SCRIPT=${ROOT_BUILD_DIR}/{{ NEML2_BUILD_SCRIPT }}

        # Clone neml2
        NEML2_SRC_DIR=${ROOT_BUILD_DIR}/neml2
        git clone --depth 1 {{ NEML2_GIT_REMOTE }} ${NEML2_SRC_DIR}
        cd ${NEML2_SRC_DIR}
        git fetch --depth 1 origin {{ NEML2_GIT_SHA }}
        git checkout {{ NEML2_GIT_SHA }}
        git submodule update --init --recursive --depth 1

{% if PROFILING is defined %}
        METHODS="oprof"
{%- else %}
        METHODS="opt devel dbg"
{%- endif %}

        # Build neml2
        cd ${ROOT_BUILD_DIR}
        NEML2_LOGS=${NEML2_DIR}/logs
        mkdir -p ${NEML2_LOGS}
        METHODS="$METHODS" \
        NEML2_SRC_DIR=${NEML2_SRC_DIR} \
        NEML2_DIR=${NEML2_DIR} \
        LIBTORCH_DIR={{ LIBTORCH_DIR }} \
        WASP_DIR={{ WASP_DIR }} \
            ${NEML2_BUILD_SCRIPT} \
                --skip-submodule-update \
                -DCMAKE_C_FLAGS="${OPTFLAGS[*]}" \
                -DCMAKE_CXX_FLAGS="${OPTFLAGS[*]}" 2>&1 | tee ${NEML2_LOGS}/build.log

        # Cleanup
        rm -rf ${NEML2_SRC_DIR} ${NEML2_BUILD_SCRIPT}
    )
{%- endif %}

{%- if WITH_MFEM %}
    # Build conduit
    (
        cd ${ROOT_BUILD_DIR}

        # Clone conduit
        CONDUIT_SRC_DIR=${ROOT_BUILD_DIR}/conduit
        git clone --depth 1 {{ CONDUIT_GIT_REMOTE }} ${CONDUIT_SRC_DIR}
        cd ${CONDUIT_SRC_DIR}
        git fetch --depth 1 origin {{ CONDUIT_GIT_SHA }}
        git checkout {{ CONDUIT_GIT_SHA }}
        git submodule update --init --depth 1

        # Load conduit options
        IFS=' ' read -r -a CONDUIT_OPTIONS <<< "{{ CONDUIT_OPTIONS }}"

        # Install conduit
        CONDUIT_DIR={{ CONDUIT_DIR }}
        CONDUIT_BUILD_SCRIPT=${ROOT_BUILD_DIR}/{{ CONDUIT_BUILD_SCRIPT }}
        CONDUIT_LOGS=${CONDUIT_DIR}/logs
        mkdir -p ${CONDUIT_LOGS}
        CONDUIT_DIR=${CONDUIT_DIR} \
        CONDUIT_SRC_DIR=${CONDUIT_SRC_DIR} \
            ${CONDUIT_BUILD_SCRIPT} \
                -DCMAKE_C_FLAGS="${OPTFLAGS[*]}" \
                -DCMAKE_CXX_FLAGS="${OPTFLAGS[*]}" \
                "${CONDUIT_OPTIONS[@]}" 2>&1 | tee ${CONDUIT_LOGS}/build.log

        # Cleanup
        rm -rf ${CONDUIT_SRC_DIR} ${CONDUIT_BUILD_SCRIPT}
    )

    # Build mfem
    (
        cd ${ROOT_BUILD_DIR}

        # Clone mfem
        MFEM_SRC_DIR=${ROOT_BUILD_DIR}/mfem
        git clone --depth 1 {{ MFEM_GIT_REMOTE }} ${MFEM_SRC_DIR}
        cd ${MFEM_SRC_DIR}
        git fetch --depth 1 origin {{ MFEM_GIT_SHA }}
        git checkout {{ MFEM_GIT_SHA }}

        # Load mfem options
        IFS=' ' read -r -a MFEM_OPTIONS <<< "{{ MFEM_OPTIONS }}"

        # Additional mfem options with cuda
        if [ -n "${CUDA_DIR:-}" ]; then
            MFEM_OPTIONS+=(
                "-DMFEM_USE_CUDA=ON"
                "-DCUDA_ARCH=sm_80"
                # The build environment lacks libnvidia-ml.so.1, which PETSc needs,
                # so we bypass the test that MFEM uses to check PETSc's installation
                # during CMake configuration.
                "-DPETSC_EXECUTABLE_RUNS=YES"
            )
            # Expose the cuda headers
            export CPATH=${CUDA_DIR}/include:${CPATH:-}
        fi

        # Install mfem
        MFEM_DIR={{ MFEM_DIR }}
        MFEM_BUILD_SCRIPT=${ROOT_BUILD_DIR}/{{ MFEM_BUILD_SCRIPT }}
        MFEM_LOGS=${MFEM_DIR}/logs
        mkdir -p ${MFEM_LOGS}
        MFEM_DIR=${MFEM_DIR} \
        MFEM_SRC_DIR=${MFEM_SRC_DIR} \
        CONDUIT_DIR={{ CONDUIT_DIR }} \
            ${MFEM_BUILD_SCRIPT} \
                -DCMAKE_C_FLAGS="${OPTFLAGS[*]}" \
                -DCMAKE_CXX_FLAGS="${OPTFLAGS[*]}" \
                "${MFEM_OPTIONS[@]}" 2>&1 | tee ${MFEM_LOGS}/build.log

        # Cleanup
        rm -rf ${MFEM_SRC_DIR} ${MFEM_BUILD_SCRIPT}
    )
{%- endif %}

    # Install node.js. Requested by dschwen for bison
    INSTALLS=("nodejs" "npm")
    if is_rocky; then
        dnf install -y "${INSTALLS[@]}"
    elif is_ubuntu; then
        apt-get install -y --no-install-recommends "${INSTALLS[@]}"
    fi

    # Clean up
    clean_system_packages
    rm -rf ${ROOT_BUILD_DIR}

%files
    # python requirements
    {{ MOOSE_DIR }}/requirements.txt /root/requirements.txt
    # code-server helpers
    {{ FILES_DIR }}/opt/code-server/bin/code-server-setup-extensions /opt/code-server/bin/code-server-setup-extensions
    {{ FILES_DIR }}/opt/code-server/bin/code-server-start /opt/code-server/bin/code-server-start
    # wasp
    {{ MOOSE_DIR }}/scripts/{{ WASP_BUILD_SCRIPT }} {{ ROOT_BUILD_DIR }}/{{ WASP_BUILD_SCRIPT }}
    {{ MOOSE_DIR }}/scripts/configure_wasp.sh {{ ROOT_BUILD_DIR }}/configure_wasp.sh
    # mfem
    {{ MOOSE_DIR }}/scripts/{{ MFEM_BUILD_SCRIPT }} {{ ROOT_BUILD_DIR }}/{{ MFEM_BUILD_SCRIPT }}
    {{ MOOSE_DIR }}/scripts/{{ CONDUIT_BUILD_SCRIPT }} {{ ROOT_BUILD_DIR }}/{{ CONDUIT_BUILD_SCRIPT }}
{% if WITHOUT_PYTORCH is not defined %}
    # libtorch
    {{ MOOSE_DIR }}/scripts/configure_libtorch.sh {{ ROOT_BUILD_DIR }}/configure_libtorch.sh
    # neml2
    {{ MOOSE_DIR }}/scripts/configure_neml2.sh {{ ROOT_BUILD_DIR }}/configure_neml2.sh
    {{ MOOSE_DIR }}/scripts/{{ NEML2_BUILD_SCRIPT }} {{ ROOT_BUILD_DIR }}/{{ NEML2_BUILD_SCRIPT }}
{%- endif %}
