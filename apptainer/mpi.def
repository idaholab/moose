{#- Required jinja arguments                                                                  -#}
{#- MOOSE_DIR: Path on the host to the MOOSE repository                                       -#}

{#- MOOSE_JOBS: Number of jobs to pass to the builds                                          -#}
{#- Optional jinja arguments                                                                  -#}
{#- ALTERNATE_FROM: Set an alternate from (currently supported: clang, clang_min, gcc_min)    -#}

{#- The files directory for this definition                                                   -#}
{%- set FILES_DIR = MOOSE_DIR + '/apptainer/files/mpi' -%}

Bootstrap: docker
{%- if ALTERNATE_FROM == "clang" %}
From: ghcr.io/idaholab/moose-mpibase/rocky:8.10-clang20.1.8-mpich5.0.0_2026.03.09
{%- elif ALTERNATE_FROM == "clang_min" %}
From: ghcr.io/idaholab/moose-mpibase/rocky:8.10-clang14.0.6-mpich5.0.0_2026.03.09
{%- elif ALTERNATE_FROM == "cuda" %}
From: ghcr.io/idaholab/moose-mpibase/rocky:8.10-cuda12.9.1-gcc13.3.1-mpich5.0.0-openmpi5.0.10_2026.03.09
{%- elif ALTERNATE_FROM == "gcc_min" %}
From: ghcr.io/idaholab/moose-mpibase/rocky:8.10-gcc9.2.1-mpich5.0.0_2026.03.09
{%- elif ALTERNATE_FROM == "intel" %}
From: ghcr.io/idaholab/moose-mpibase/rocky:8.10-oneapi2025.3.2-mpich4.3.2_2026.03.09
{%- elif ALTERNATE_FROM == "rocky9" %}
From: ghcr.io/idaholab/moose-mpibase/rocky:9.7-gcc13.3.1-mpich4.3.2-openmpi5.0.10_2026.03.09
{%- elif ALTERNATE_FROM == "ubuntu" %}
From: ghcr.io/idaholab/moose-mpibase/ubuntu:24.04-gcc14.2.0-mpich5.0.0-openmpi5.0.10_2026.03.24
{%- elif ALTERNATE_FROM == "ubuntu_cuda" %}
From: ghcr.io/idaholab/moose-mpibase/ubuntu:24.04-cuda12.9.1-gcc13.3.0-mpich5.0.0-openmpi5.0.10_2026.03.24
{%- else %}
From: ghcr.io/idaholab/moose-mpibase/rocky:8.10-gcc13.3.1-mpich5.0.0-openmpi5.0.10_2026.03.09
{%- endif %}

%environment
    # Fix locale warnings
    export LC_ALL=C

    # Environment from underyling docker image
    if [ -f "/moose_env.sh" ]; then
        . /moose_env.sh
    fi

%post -c /bin/bash
    umask 022
    set -eo pipefail

    # Determine OS
    grep -q "rhel" /etc/os-release && IS_RHEL=1
    if [ -n "$IS_RHEL" ]; then
        grep 'VERSION=\"8.' /etc/os-release && IS_RHEL_8=1
        grep 'VERSION=\"9.' /etc/os-release && IS_RHEL_9=1
        if [ -z "$IS_RHEL_8" ] && [ -z "$IS_RHEL_9" ]; then
            echo "Unknown rhel version"
            exit 1
        fi
    fi
    grep -q "debian" /etc/os-release && IS_DEBIAN=1
    if [ -z "$IS_RHEL" ] && [ -z "$IS_DEBIAN" ]; then
        echo "Unknown OS"
        exit 1
    fi

    # Remove apptainer if it's installed
    if [ -n "$IS_RHEL" ]; then
        if dnf list installed apptainer &> /dev/null; then
            dnf remove -y apptainer
        fi
    fi

    # Enable additional repos for rhel
    if [ -n "$IS_RHEL" ]; then
        dnf install -y dnf-plugins-core
        if [ -n "$IS_RHEL_8" ]; then
            dnf config-manager --set-enabled powertools
            dnf install -y redhat-lsb-core.x86_64
        elif [ -n "$IS_RHEL_9" ]; then
            dnf config-manager --set-enabled crb
        fi
        dnf install -y epel-release
    fi

    # Additional installs
    if [ -n "$IS_RHEL" ]; then
        dnf install -y emacs make cmake diffutils bison flex perl-IO-Compress perl-JSON \
            perl-JSON-PP libtirpc libtirpc-devel zlib-devel patch patchutils libpng \
            libpng-devel valgrind cppunit doxygen fftw-devel gsl-devel libtool autoconf \
            automake cppunit-devel glpk-devel patchelf lcov bash-completion
    elif [ -n "$IS_DEBIAN" ]; then
        apt-get update
        apt-get install -y --no-install-recommends \
            emacs make cmake diffutils bison flex libio-compress-perl libjson-perl \
            libjson-pp-perl libtirpc3 libtirpc-dev zlib1g-dev patch patchutils libpng16-16 \
            libpng-dev valgrind libcppunit-1.15-0 doxygen libfftw3-dev libgsl-dev libtool autoconf \
            automake libcppunit-dev libglpk-dev patchelf lcov bash-completion
    fi

    # Clean after install
    if [ -n "$IS_RHEL" ]; then
        dnf clean all
    elif [ -n "$IS_DEBIAN" ]; then
        apt-get autoremove -y
        apt-get clean
        rm -rf /var/lib/apt/lists/*
    fi

%test
    if [ -n "$MOOSE_MPICH_DIR" ]; then
        ${MOOSE_MPICH_DIR}/bin/mpiexec --version
    fi
    if [ -n "$MOOSE_OPENMPI_DIR" ]; then
        ${MOOSE_OPENMPI_DIR}/bin/mpiexec --version
        ${MOOSE_OPENMPI_DIR}/bin/ompi_info
    fi

%files
    {{ FILES_DIR }}/.singularity.d/env/02-fix-actions.sh /.singularity.d/env/02-fix-actions.sh
    {{ FILES_DIR }}/.singularity.d/moose_bashrc /.singularity.d/moose_bashrc
