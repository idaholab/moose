[Tests]
  design = 'QuadraticPredictor.md'
  issues = '#32982'

  [constant_dt]
    type = 'CSVDiff'
    input = 'quadratic_predictor.i'
    csvdiff = 'quadratic_predictor_out.csv'
    abs_zero = 1e-12
    ignore_columns = 'num_nonlinear_iterations'

    requirement = 'The system shall support a quadratic solution predictor for constant '
                  'time-step sizes.'
  []

  [variable_dt]
    type = 'CSVDiff'
    input = 'quadratic_predictor_variable_dt.i'
    csvdiff = 'quadratic_predictor_variable_dt_out.csv'
    abs_zero = 1e-12
    ignore_columns = 'num_nonlinear_iterations'

    requirement = 'The system shall support a quadratic solution predictor for variable '
                  'time-step sizes.'
  []

  [variable_dt_cubic]
    requirement = 'The system shall apply nonuniform time-step quadratic prediction to solution '
                  'histories that are not exactly quadratic in time'

    [predicted]
      type = 'CSVDiff'
      input = 'quadratic_predictor_variable_dt_cubic.i'
      csvdiff = 'quadratic_predictor_variable_dt_cubic_out.csv'
      abs_zero = 1e-12
      ignore_columns = 'num_nonlinear_iterations'

      detail = 'by computing a non-exact predicted solve history and'
    []

    [no_predictor]
      type = 'CSVDiff'
      input = 'quadratic_predictor_variable_dt_cubic_no_predictor.i'
      csvdiff = 'quadratic_predictor_variable_dt_cubic_no_predictor_out.csv'
      abs_zero = 1e-12
      ignore_columns = 'num_nonlinear_iterations'

      detail = 'by computing a no-predictor reference solve history and'
    []

    [improves_initial_residual]
      type = 'RunCommand'
      command = 'python3 - <<PY
import csv
import sys

with open("quadratic_predictor_variable_dt_cubic_out.csv", newline="") as csvfile:
    predicted = list(csv.DictReader(csvfile))

with open("quadratic_predictor_variable_dt_cubic_no_predictor_out.csv", newline="") as csvfile:
    no_predictor = list(csv.DictReader(csvfile))

for row_index in (3, 4):
    predicted_residual = float(predicted[row_index]["initial_residual"])
    no_predictor_residual = float(no_predictor[row_index]["initial_residual"])
    if predicted_residual >= no_predictor_residual:
        print(f"Quadratic predictor did not improve row {row_index}.")
        sys.exit(1)
PY'
      use_shell = true
      prereq = 'variable_dt_cubic/predicted variable_dt_cubic/no_predictor'

      detail = 'by reducing the initial residual after enough accepted history is available.'
    []
  []

  [scale_zero]
    type = 'CSVDiff'
    input = 'quadratic_predictor.i'
    csvdiff = 'quadratic_predictor_scale_zero_out.csv'
    cli_args = 'Executioner/Predictor/scale=0 Outputs/file_base=quadratic_predictor_scale_zero_out'
    abs_zero = 1e-12
    ignore_columns = 'num_nonlinear_iterations'

    # The scale factor makes this a no-op predictor: the initial guess remains u^n.
    requirement = 'The system shall support disabling the quadratic predictor by setting the '
                  'scale factor to zero.'
  []

  [print]
    requirement = 'The system shall print the quadratic predictor scale factor to the output stream'

    [nonzero]
      type = 'RunApp'
      input = 'quadratic_predictor.i'
      cli_args = 'Executioner/Predictor/scale=1e-10'
      expect_out = 'Applying quadratic predictor with scale factor = 1e-10'

      detail = 'for a nonzero scale factor and'
    []

    [zero]
      type = 'RunApp'
      input = 'quadratic_predictor.i'
      cli_args = 'Executioner/Predictor/scale=0'
      expect_out = 'Skipping quadratic predictor because scale factor = 0'

      detail = 'for a zero scale factor that triggers the no-op early return.'
    []
  []

  [skip_times_old]
    type = 'CSVDiff'
    input = 'quadratic_predictor_skip_times_old.i'
    csvdiff = 'quadratic_predictor_skip_times_old_out.csv'
    abs_zero = 1e-12
    ignore_columns = 'num_nonlinear_iterations'

    requirement = 'The system shall support skipping quadratic prediction based on previous '
                  'solution times.'
  []

  [repeated_timestep]
    type = 'CSVDiff'
    input = 'quadratic_predictor_repeated_timestep.i'
    csvdiff = 'quadratic_predictor_repeated_timestep_out.csv'
    abs_zero = 1e-12
    ignore_columns = 'num_nonlinear_iterations'
    restep = false # This test intentionally exercises failed timestep behavior.

    requirement = 'The system shall preserve quadratic predictor history on a repeated time step.'
  []

  [restart]
    requirement = 'The system shall restart quadratic predictor state from checkpoint output.'

    [part1]
      type = 'RunApp'
      input = 'quadratic_predictor.i'
      cli_args = 'Outputs/checkpoint=true Outputs/file_base=quadratic_predictor_restart_part1'
      recover = false

      detail = 'by writing a checkpoint after enough solution history is available and'
    []

    [part2]
      type = 'CSVDiff'
      input = 'quadratic_predictor_restart_part2.i'
      csvdiff = 'quadratic_predictor_restart_part2_out.csv'
      prereq = 'restart/part1'
      delete_output_before_running = false
      recover = false
      abs_zero = 1e-12
      ignore_columns = 'num_nonlinear_iterations'

      detail = 'by continuing from the checkpoint with exact quadratic predictions.'
    []
  []
[]
