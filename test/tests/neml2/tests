[Tests]
  # The original issue is idaholab/blackbear#333
  issues = '#26450 #26920'
  design = 'NEML2/index.md NEML2Action.md'
  [custom_model]
    requirement = 'The framework shall be capable of running custom NEML2 models implemented in MOOSE (optionally with automatic differentiation).'
    type = Exodiff
    input = 'custom_model.i'
    exodiff = 'custom_model_out.e'
    capabilities = 'libtorch & neml2'
    valgrind = heavy
  []
  # cpp-aoti compile-then-run pipeline: compile the NEML2TestModel to an AOTI artifact, then
  # evaluate it through the cpp-aoti runtime and check it reproduces the cpp-eager result (the
  # run loads the artifact, so it implicitly verifies the compile produced it). Requires the
  # activated neml2 conda environment (neml2-compile on PATH).
  [aoti_compile]
    requirement = 'The framework shall compile a NEML2 model to ahead-of-time (AOTI) artifacts.'
    type = RunCommand
    command = 'neml2-compile --model model models/custom_model.i --device cpu --output-dir aoti_artifacts --load models/test_models.py -d product:A'
    capabilities = 'libtorch & neml2'
    valgrind = none
  []
  [aoti_run]
    requirement = 'The framework shall evaluate a NEML2 model through the cpp-aoti runtime, reproducing the cpp-eager result.'
    type = Exodiff
    prereq = 'aoti_compile'
    input = 'custom_model_aoti.i'
    exodiff = 'custom_model_aoti_out.e'
    capabilities = 'libtorch & neml2'
    valgrind = none
  []
  [neml2_error]
    requirement = 'The framework shall be capable of capturing errors that occur during the evaluation of a NEML2 model.'
    type = RunException
    input = 'custom_model.i'
    cli_args = 'NEML2/all/model=error'
    expect_err = 'NEML2 model evaluation failed with a non-recoverable error'
    collections = 'SYSTEM'
    capabilities = 'libtorch & neml2'
    valgrind = none
  []
  [no_neml2]
    requirement = 'The framework shall throw an error upon instantiation of NEML2 interface objects if NEML2 is not available.'
    type = RunException
    input = 'custom_model.i'
    expect_err = 'The `NEML2` library is required but not enabled'
    collections = 'SYSTEM'
    capabilities = '!neml2'
  []
  [infer_io_type_ambiguous]
    requirement = 'The framework shall throw an error when the MOOSE data type for a NEML2 scalar input variable cannot be unambiguously inferred because the name matches multiple MOOSE entities.'
    type = RunException
    input = 'custom_model.i'
    cli_args = 'Functions/A/type=ParsedFunction Functions/A/expression=1.0'
    expect_err = 'Trying to infer MOOSE data type for NEML2 variable A\. The name matches multiple types \(function variable\s*\)'
    collections = 'SYSTEM'
    capabilities = 'libtorch & neml2'
  []
  [stateful_consistency]
    issues = '#33197'
    collections = 'SYSTEM'
    requirement = 'The framework shall report a clear error, rather than crashing during stateful '
                  'material property initialization, when a NEML2 model is configured such that '
    [initialize_outputs_not_an_output]
      detail = 'a variable requested via initialize_outputs is not a model output, or'
      type = RunException
      input = 'custom_model.i'
      cli_args = 'NEML2/all/initialize_outputs=nonexistent NEML2/all/initialize_output_values=B'
      expect_err = "'nonexistent' is not an output of the NEML2 model and therefore cannot be initialized"
      capabilities = 'libtorch & neml2'
    []
    [stateful_input_without_output]
      detail = 'the old value of a variable is consumed as an input while the variable is neither a current input nor an output.'
      type = RunException
      input = 'stateful_consistency.i'
      expect_err = "takes the old value of 'foo' \(foo~1\) as an input, but the model neither takes 'foo' as a current input nor produces it as an output"
      capabilities = 'libtorch & neml2'
    []
  []
  [model_parameter]
    requirement = 'The framework shall be capable of using MOOSE data as NEML2 model parameters.'
    type = Exodiff
    input = 'parameter.i'
    exodiff = 'parameter_out.e'
    capabilities = 'libtorch & neml2'
    valgrind = heavy
  []
  [block_restriction]
    issues = '#27493'
    collections = 'SYSTEM'
    requirement = 'The framework shall be capable of defining, for multiple subdomains, '
    [same_model]
      detail = 'the same NEML2 model running on the same device.'
      type = Exodiff
      input = 'blocks_same_model.i'
      exodiff = 'blocks_same_model_out.e'
      capabilities = 'libtorch & neml2'
      valgrind = heavy
    []
    [different_model]
      detail = 'different NEML2 models running on the same device.'
      type = Exodiff
      input = 'blocks_different_model.i'
      exodiff = 'blocks_different_model_out.e'
      capabilities = 'libtorch & neml2'
      valgrind = heavy
    []
  []
  [empty]
    requirement = "The framework shall be capable of running custom NEML2 models and handling empty "
                  "input batches without errors."
    type = Exodiff
    input = 'blocks_empty_neml2.i'
    exodiff = 'blocks_empty_neml2_out.e'
    capabilities = 'libtorch & neml2'
    valgrind = heavy
    min_parallel = 2
    max_parallel = 2
  []
  [multiple_inputs]
    requirement = 'The framework shall be capable of running custom NEML2 models defined in different NEML2 input files.'
    type = Exodiff
    input = 'multiple_input_files.i'
    exodiff = 'multiple_input_files_out.e'
    capabilities = 'libtorch & neml2'
    valgrind = heavy
  []
  [mesh_change]
    requirement = 'The framework shall be capable of running NEML2 models after a mesh change.'
    type = Exodiff
    input = 'mesh_change.i'
    exodiff = 'mesh_change_out.e mesh_change_out.e-s002 mesh_change_out.e-s003 mesh_change_out.e-s004 mesh_change_out.e-s005'
    capabilities = 'libtorch & neml2'
    valgrind = heavy
  []
[]
