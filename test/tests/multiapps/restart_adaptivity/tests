[Tests]
  design = 'syntax/MultiApps/index.md syntax/Adaptivity/index.md'

  [group]
    requirement = "The system shall report a clear diagnostic when a sub-application backup is restored onto a different independently adapted mesh topology."

    [first]
      type = RunApp
      input = parent.i
      detail = "The test first creates a checkpoint containing a MultiApp backup with an initially adapted sub-application mesh."
    []

    [second]
      type = RunException
      input = parent_restart.i
      prereq = group/first
      expect_err = 'in-memory MultiApp backups do not restore independent sub-application mesh topology'
      detail = "The test then reports the unsupported independent adaptive sub-application restore with a targeted error."
    []
  []
[]
