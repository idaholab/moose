[Tests]
  issues = '#25412'
  design = 'MooseApp.md'
  [framework]
    type = RunApp
    input = citations.i
    cli_args = '--check-input --citations'
    expect_out = 'harbour2025moose'
    requirement = "The system shall report, in BibTeX format, the current framework reference that "
                  "should be cited when the --citations command-line option is provided."
  []
  [petsc]
    type = RunApp
    input = citations.i
    cli_args = '--check-input --citations'
    expect_out = 'petsc-efficient'
    requirement = "The system shall report the PETSc references that should be cited when the "
                  "--citations command-line option is provided."
  []
  [not_requested]
    type = RunApp
    input = citations.i
    cli_args = '--check-input'
    absent_out = 'harbour2025moose'
    requirement = "The system shall not report citations when the --citations command-line option "
                  "is not provided."
  []
  [multiapp]
    type = RunApp
    input = multiapp.i
    cli_args = '--citations'
    expect_out = 'harbour2025moose'
    recover = false
    requirement = "The system shall report citations for the modules and objects used inside "
                  "MultiApp subapps, not just those constructed in the master app, when the "
                  "--citations command-line option is provided."
  []
  [multiapp_subapp_backend]
    type = RunApp
    input = multiapp.i
    cli_args = "MultiApps/sub/input_files=../../mfem/kernels/diffusion.i sub0:Outputs/active='' "
               "--citations"
    expect_out = 'anderson2021mfem'
    capabilities = 'mfem'
    recover = false
    requirement = "The system shall report the finite element backend citation for a backend used "
                  "only inside a MultiApp subapp, which the master app itself does not use, when "
                  "the --citations command-line option is provided."
  []
  [key_sync]
    type = RunCommand
    command = 'python3 check_citation_keys.py'
    requirement = "The system shall ensure that every citation key registered in source code is "
                  "defined in a documentation BibTeX file."
  []
[]
