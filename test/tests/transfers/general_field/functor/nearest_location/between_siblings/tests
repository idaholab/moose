[Tests]
  issues = '#13754 #19451'
  design = 'MultiAppGeneralFieldNearestLocationTransfer.md'

  [from_sub_to_sub]
    requirement = "The system shall support functor transfers between multiapps"
    [nodal_nodal]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'nodal_nodal_ma10.e nodal_nodal_ma20.e'
      cli_args = "Outputs/file_base=nodal_nodal
                  Transfers/active='app1_to_2_nodal_nodal app2_to_1_nodal_nodal'
                  MultiApps/ma1/cli_args='Outputs/show=received_nodal'"
      detail = 'between nodal variables,'
    []
    [elem_elem]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'elem_elem_ma10.e elem_elem_ma20.e'
      cli_args = "Outputs/file_base=elem_elem Transfers/active='app1_to_2_elem_elem "
                 "app2_to_1_elem_elem'"
      detail = 'between elemental variables,'
    []
    [elem_nodal]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'elem_nodal_ma10.e elem_nodal_ma20.e'
      cli_args = "Outputs/file_base=elem_nodal Transfers/active='app1_to_2_elem_nodal "
                 "app2_to_1_elem_nodal'"
      detail = 'from elemental to nodal variables,'
      # Transferring between nodes and centroids
      allow_warnings = true
    []

    [one_app_serial]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'nodal_nodal_serial_ma10.e nodal_nodal_serial_ma20.e'
      cli_args = "Outputs/file_base=nodal_nodal_serial
                  Transfers/active='app1_to_2_nodal_nodal app2_to_1_nodal_nodal'
                  MultiApps/ma1/max_procs_per_app=1
                  MultiApps/ma1/cli_args='Outputs/show=received_nodal'"
      detail = 'when one multiapp is run in serial,'
    []

    # Block restriction of the transfer only is tested in ../subdomain
    [block_restriction_variables_same_type]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'block_restricted_same_ma10.e block_restricted_same_ma20.e'
      cli_args = "Outputs/file_base=block_restricted_same Transfers/active='app1_to_2_nodal_nodal app2_to_1_nodal_nodal app1_to_2_elem_elem app2_to_1_elem_elem'
                  MultiApps/ma1/cli_args='AuxVariables/sent_nodal/block=1;AuxVariables/received_nodal/block=1;AuxVariables/sent_elem/block=1;AuxVariables/received_elem/block=1'
                  MultiApps/ma2/cli_args='AuxVariables/sent_nodal/block=1;AuxVariables/received_nodal/block=1;AuxVariables/sent_elem/block=1;AuxVariables/received_elem/block=1'"
      detail = 'with block restricted variables of matching types,'
    []
    [block_restriction_variables_different_type]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'block_restricted_diff_ma10.e block_restricted_diff_ma20.e'
      cli_args = "Outputs/file_base=block_restricted_diff Transfers/active='app1_to_2_nodal_elem app2_to_1_nodal_elem app1_to_2_elem_nodal app2_to_1_elem_nodal'
                  MultiApps/ma1/cli_args='AuxVariables/sent_nodal/block=1;AuxVariables/received_nodal/block=1;AuxVariables/sent_elem/block=1;AuxVariables/received_elem/block=1'
                  MultiApps/ma2/cli_args='AuxVariables/sent_nodal/block=1;AuxVariables/received_nodal/block=1;AuxVariables/sent_elem/block=1;AuxVariables/received_elem/block=1'"
      detail = 'with block restricted variables of different types.'
      # Transferring between nodes and centroids
      allow_warnings = true
    []
    [extrapolation_target_mesh]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'post_extrapolation_ma10.e post_extrapolation_ma20.e'
      cli_args = "Outputs/file_base=post_extrapolation
                  Transfers/active='app1_to_2_nodal_nodal app2_to_1_nodal_nodal app1_to_2_elem_elem app2_to_1_elem_elem'
                  extrapolation_behavior_node='flat'
                  extrapolation_behavior_elem='flat'
                  GlobalParams/post_transfer_extrapolation=nearest-valid-target
                  MultiApps/ma1/cli_args='AuxVariables/ghosting_request/family=MONOMIAL_VEC;AuxVariables/ghosting_request/order=CONSTANT;AuxVariables/ghosting_request/AuxKernel/type=FunctorElementalGradientAux;AuxVariables/ghosting_request/AuxKernel/functor=sent_elem;AuxVariables/ghosting_request/outputs=none'
                  MultiApps/ma2/cli_args='AuxVariables/ghosting_request/family=MONOMIAL_VEC;AuxVariables/ghosting_request/order=CONSTANT;AuxVariables/ghosting_request/AuxKernel/type=FunctorElementalGradientAux;AuxVariables/ghosting_request/AuxKernel/functor=sent_elem;AuxVariables/ghosting_request/outputs=none'
                  GlobalParams/error_on_miss=false"
      detail = 'with an extrapolation post-treatment from the transferred values on the target mesh onto locations missing transferred data.'
      # Note: we are adding an object to the multiapps to get the desired ghosting.
      # no longer needed once #32533 is addressed
      # Meshes are not closely overlapping, post-treatment will not be able to correct every point
      allow_warnings = true
    []
  []
[]
