[Tests]
  issues = '#30300'
  design = '../../../../modules/doc/content/framework_development/sanity_checking.md ../source/interfaces/BlockRestrictable.md'
  [block_test]
    requirement = 'The system shall be capable of using default_block in [Problem] to (1) enforce that only blocks listed in default_block are considered during kernel and material coverage checks, and (2) automatically apply default_block as the block restriction for kernels and variables unless explicitly overridden.'
    [default_block]
      type = 'Exodiff'
      input = 'diffusion_with_null_material.i'
      exodiff = 'diffusion_with_null_material_out.e'
      detail = 'Check the functionality of default_block in [Problem].'
    []
    [different_kernel_different_blocks]
      type = 'Exodiff'
      input = 'diffusion_with_null_material_different_kernel_differnt_blocks.i'
      exodiff = 'diffusion_with_null_material_different_kernel_differnt_blocks_out.e'
      detail = 'Check whether different kernels can be assigned to different blocks, as long as the block IDs belong to the default_block list.'
    []
    [kernel_coverage_override]
      type = 'Exodiff'
      input = 'diffusion_with_null_material_kernel_coverage_override.i'
      exodiff = 'diffusion_with_null_material_kernel_coverage_override_out.e'
      detail = 'Check whether kernel coverage override is allowed even when default_block is specified.'
    []
  []
[]
