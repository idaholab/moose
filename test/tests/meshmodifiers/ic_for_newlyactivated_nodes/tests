[Tests]
  issues = '#30627'
  design = 'ElementSubdomainModifier.md'

  [group]
    requirement = 'The framework shall include the ability to set initial conditions on newly activated nodes during simulation.'

    [IC_for_newlyactivated_nodes]
      type = 'Exodiff'
      input = 'external_moving_boundary_npr.i'
      exodiff = 'external_moving_boundary_npr_out.e external_moving_boundary_npr_out.e-s002 external_moving_boundary_npr_out.e-s003 external_moving_boundary_npr_out.e-s004'
      detail = 'The system shall set initial conditions on newly activated nodes during the simulation.'
    []

    [IC_for_newlyactivated_nodes_two_variables_different_IC]
      type = 'Exodiff'
      input = 'external_moving_boundary_npr_two_variables_only_setIC_for_UO_other_follow_variable.i'
      exodiff = 'external_moving_boundary_npr_two_variables_only_setIC_for_UO_other_follow_variable_out.e external_moving_boundary_npr_two_variables_only_setIC_for_UO_other_follow_variable_out.e-s002 external_moving_boundary_npr_two_variables_only_setIC_for_UO_other_follow_variable_out.e-s003 external_moving_boundary_npr_two_variables_only_setIC_for_UO_other_follow_variable_out.e-s004'
      detail = 'The system shall allow different initial condition strategies for each variable on newly activated nodes. In this case, variable `diff` uses nodal patch recovery, while variable `diff2` is set to 10.0.'
    []

    [IC_for_newlyactivated_nodes_two_variables_same_IC]
      type = 'Exodiff'
      input = 'external_moving_boundary_npr_two_variables_npr_for_both.i'
      exodiff = 'external_moving_boundary_npr_two_variables_npr_for_both_out.e external_moving_boundary_npr_two_variables_npr_for_both_out.e-s002 external_moving_boundary_npr_two_variables_npr_for_both_out.e-s003 external_moving_boundary_npr_two_variables_npr_for_both_out.e-s004'
      detail = 'The system shall allow a shared initial condition to be applied to multiple variables using a single IC strategy when both are listed in `nodal_patch_recovery_uo`.'
    []

    [IC_for_newlyactivated_nodes_two_variables_normal_setting]
      type = 'Exodiff'
      input = 'external_moving_boundary_npr_two_variables_npr_normal_set.i'
      exodiff = 'external_moving_boundary_npr_two_variables_npr_normal_set_out.e external_moving_boundary_npr_two_variables_npr_normal_set_out.e-s002 external_moving_boundary_npr_two_variables_npr_normal_set_out.e-s003 external_moving_boundary_npr_two_variables_npr_normal_set_out.e-s004'
      detail = 'The system shall accept consistent vector sizes for `ic_strategy`, `ic_variables`, and `nodal_patch_recovery_uo` when applying initial conditions.'
    []

    [npr_element_not_specified_by_user]
      type = 'Exodiff'
      input = 'external_moving_boundary_npr_elem_not_provide.i'
      exodiff = 'external_moving_boundary_npr_elem_not_provide_out.e external_moving_boundary_npr_elem_not_provide_out.e-s002'
      detail = 'The system shall support nodal patch recovery using all elements in restricted blocks when `use_specific_elements = false`.'
    []

    [IC_default]
      type = 'Exodiff'
      input = 'external_moving_boundary_no_unsolved_blocks_all_IC_default.i'
      exodiff = 'external_moving_boundary_no_unsolved_blocks_all_IC_default_out.e external_moving_boundary_no_unsolved_blocks_all_IC_default_out.e-s002 external_moving_boundary_no_unsolved_blocks_all_IC_default_out.e-s003 external_moving_boundary_no_unsolved_blocks_all_IC_default_out.e-s004'
      detail = 'The system shall run with `ic_strategy = IC_DEFAULT` without requiring `nodal_patch_recovery_uo` or `unsolved_blocks`.'
    []

    [IC_for_newlyactivated_nodes_quad9]
      type = 'Exodiff'
      input = 'external_moving_boundary_npr_Quad9.i'
      exodiff = 'external_moving_boundary_npr_Quad9_out.e external_moving_boundary_npr_Quad9_out.e-s002 external_moving_boundary_npr_Quad9_out.e-s003 external_moving_boundary_npr_Quad9_out.e-s004'
      detail = 'The system shall support setting initial conditions on newly activated nodes for higher-order elements such as Quad9.'
    []

    [IC_for_auxiliary_monomial_variables]
      type = 'Exodiff'
      input = 'npr_IC_aux.i'
      exodiff = 'npr_IC_aux_out.e npr_IC_aux_out.e-s002 npr_IC_aux_out.e-s003 npr_IC_aux_out.e-s004'
      detail = 'The system shall support setting initial conditions on newly activated elements described by monomial auxiliary variables.'
    []

    [IC_for_auxiliary_lagrange_variables]
      type = 'Exodiff'
      input = 'npr_IC_nodal_based_aux.i'
      exodiff = 'npr_IC_nodal_based_aux_out.e npr_IC_nodal_based_aux_out.e-s002 npr_IC_nodal_based_aux_out.e-s003 npr_IC_nodal_based_aux_out.e-s004'
      detail = 'The system shall support setting initial conditions on newly activated nodes described by Lagrange-based auxiliary variables.'
    []

    [IC_for_default]
      type = 'Exodiff'
      input = 'external_moving_boundary_npr_three_vars.i'
      exodiff = 'external_moving_boundary_npr_three_vars_out.e external_moving_boundary_npr_three_vars_out.e-s002 external_moving_boundary_npr_three_vars_out.e-s003 external_moving_boundary_npr_three_vars_out.e-s004'
      detail = 'The system shall support setting initial conditions to all non-linear variables if the user set ic_strategy == IC_DEFAULT and no nodal_patch_recovery_uo and ic_variables is provided.'
    []

    [IC_three_variables_three_IC_strategies]
      type = 'Exodiff'
      input = 'external_moving_boundary_three_vars_three_strategies.i'
      exodiff = 'external_moving_boundary_three_vars_three_strategies_out.e external_moving_boundary_three_vars_three_strategies_out.e-s002 external_moving_boundary_three_vars_three_strategies_out.e-s003 external_moving_boundary_three_vars_three_strategies_out.e-s004'
      detail = 'The system shall support assigning different initial condition strategies -- namely, nearby element-based, k-d tree-based, and whole domain-based—to different variables.'
    []

    [IC_three_variables_three_IC_strategies_default]
      type = 'Exodiff'
      input = 'external_moving_boundary_three_vars_three_strategies_default.i'
      exodiff = 'external_moving_boundary_three_vars_three_strategies_default_out.e external_moving_boundary_three_vars_three_strategies_default_out.e-s002 external_moving_boundary_three_vars_three_strategies_default_out.e-s003 external_moving_boundary_three_vars_three_strategies_default_out.e-s004'
      detail = 'The system shall support assigning different initial condition strategies -- namely, nearby element-based, whole domain-based, and default -- to different variables.'
    []
  []

  [error_test]
    requirement = 'The system shall throw errors when invalid IC strategies are used or when input vectors have inconsistent sizes.'

    [error_ic_strategy_not_valid]
      type = RunException
      input = 'ic_strategy_not_valid.i'
      expect_err = 'Invalid option "IC_POLYNOMIAL_WHOLE" in MooseEnum.'
      detail = 'The system shall throw an error if an invalid IC strategy name is provided.'
    []

    [error_ic_strategy_more_than_ic_variables]
      type = RunException
      input = 'external_moving_boundary_npr_two_variables_npr_more_ic_strategy.i'
      expect_err = "The 'ic_strategy' parameter is not used correctly"
      detail = 'The system shall throw an error if the size of `ic_strategy` is not 1 and does not match the size of `ic_variables` or `nodal_patch_recovery_uo`.'
    []

    [npr_element_not_in_block]
      type = RunException
      input = 'external_moving_boundary_npr_element_not_in_block.i'
      expect_err = "Please use nodalPatchRecovery with elements in the block only."
      detail = 'The system shall throw an error if elements specified for nodal patch recovery are not part of any restricted block.'
    []

    [npr_no_UO_in_esm]
      type = RunException
      input = 'external_moving_boundary_npr_no_UO_in_esm.i'
      expect_err = "The 'ic_strategy' parameter is set to use polynomial extrapolation, but no 'nodal_patch_recovery_uo' is specified."
      detail = 'The system shall throw an error if polynomial extrapolation is selected but no nodal patch recovery user object is provided.'
    []

    [npr_no_UO_in_esm_only_one_poly_ic]
      type = RunException
      input = 'external_moving_boundary_npr_one_poly_no_UO_in_esm.i'
      expect_err = "The 'ic_strategy' parameter is set to use polynomial extrapolation, but no 'nodal_patch_recovery_uo' is specified."
      detail = 'The system shall throw an error if one IC strategy uses polynomial extrapolation but no nodal patch recovery user object is specified.'
    []

    [ic_no_unsolved_blocks]
      type = RunException
      input = 'external_moving_boundary_no_unsolved_blocks.i'
      expect_err = "The unsolved_blocks must be set to use the extrapolation strategy."
      detail = 'The system shall throw an error if extrapolation is used without specifying `unsolved_blocks`.'
    []

    [mismatch_IC_poly_npr_UO]
      type = RunException
      input = 'external_moving_boundary_mismatch_IC_poly_npr_UO.i'
      expect_err = "Mismatch between number of IC strategies using polynomial extrapolation and NPR UO"
      detail = 'The system shall throw an error if the number of IC strategies using polynomial extrapolation does not match the number of NPR user objects.'
    []

    [IC_default_with_unsolved_blocks]
      type = RunException
      input = 'external_moving_boundary_all_IC_default_unsolved_block_provided.i'
      expect_err = "The unsolved_blocks should not be set to use the default strategy."
      detail = 'The system shall throw an error if `unsolved_blocks` is set while using `ic_strategy = IC_DEFAULT`.'
    []

    [IC_two_defaults_no_ic_variables]
      type = RunException
      input = 'external_moving_two_IC_default.i'
      expect_err = "The 'ic_strategy' parameter has more than one value, but no 'ic_variables' are specified."
      detail = 'The system shall throw an error if multiple IC strategies are provided without defining `ic_variables`.'
    []
  []
[]
