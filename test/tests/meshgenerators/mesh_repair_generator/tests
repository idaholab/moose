[Tests]
  design = 'MeshRepairGenerator.md'
  [node_overlap]
    type = JSONDiff
    input = overlapping_fix_test.i
    jsondiff = overlapping_fix_test_json.json
    requirement = 'The system shall be able to merge overlapping nodes.'
    mesh_mode = 'replicated'
    issues = '#25107'
  []
  [element_flip]
    type = CSVDiff
    input = flip_element.i
    csvdiff = flip_element_out.csv
    requirement = 'The system shall be able to flip the orientation of negative-volume elements.'
    mesh_mode = 'replicated'
    issues = '#25107'
  []
  [separate_element_types]
    type = JSONDiff
    input = mixed_elements.i
    jsondiff = mixed_elements_json.json
    requirement = "The system shall be able to split blocks across their element's type."
    mesh_mode = 'replicated'
    issues = '#25107'
  []
  [boundary_merge]
    type = JSONDiff
    input = merge_boundaries.i
    jsondiff = merge_boundaries_json.json
    requirement = "The system shall be able to merge boundaries with the same names but different boundary IDs."
    mesh_mode = 'replicated'
    issues = '#25107'
  []
  [fix_nonconvex_polygons]
    type = RunApp
    input = 'nonconvex_polygon.i'
    cli_args = '--mesh-only'
    recover = false
    expect_out = "Number of non convex polygons: 0"
    requirement = "The system shall be able to split nonconvex polygons to turn them into convex ones."
    issues = '#32159'
    # parallel packing not implemented for polys
    mesh_mode = 'replicated'
  []
  [repair_slivers]
    type = Exodiff
    input = repair_slivers.i
    cli_args = '--mesh-only'
    exodiff = 'repair_slivers_in.e'
    recover = false
    issues = '#33151'
    requirement = "The system shall be able to repair sliver elements, flagged by the longest-edge flap test, by removing each sliver and absorbing it into its longest-edge neighbor, splitting a triangle neighbor into two triangles."
    mesh_mode = 'replicated'
  []
  [repair_slivers_by_area]
    type = Exodiff
    input = repair_slivers.i
    cli_args = 'Mesh/repair/sliver_element_flap_tol=0 Mesh/repair/sliver_element_area_fraction=0.01 --mesh-only repair_slivers_area_in.e'
    exodiff = 'repair_slivers_area_in.e'
    recover = false
    issues = '#33151'
    requirement = "The system shall be able to repair sliver elements flagged by the relative-area test."
    mesh_mode = 'replicated'
  []
  [repair_quad_slivers]
    type = RunApp
    input = repair_quad_slivers.i
    expect_out = 'Number of sliver elements repaired: 1'
    issues = '#33151'
    requirement = "The system shall be able to repair a quadrilateral sliver element by absorbing it into a neighbor, promoting the neighbor to a polygon while keeping the mesh conformal."
    mesh_mode = 'replicated'
  []
  [repair_sliver_combinations]
    type = RunApp
    input = repair_sliver_combinations.i
    expect_out = 'Number of sliver elements repaired: 4'
    issues = '#33151'
    requirement = "The system shall be able to repair quadrilateral and polygon sliver elements against triangle, quadrilateral, and polygon neighbors, promoting each neighbor to a quadrilateral or polygon while keeping the mesh conformal."
    mesh_mode = 'replicated'
  []
  [repair_interior_sliver]
    type = RunApp
    input = repair_interior_sliver.i
    expect_out = 'Number of sliver elements repaired: 1'
    issues = '#33151'
    requirement = "The system shall keep the mesh conformal when repairing an interior sliver whose non-absorbed edge is shared with another element."
    mesh_mode = 'replicated'
  []
  [repair_tet_sliver]
    type = Exodiff
    input = repair_tet_sliver.i
    cli_args = '--mesh-only'
    exodiff = 'repair_tet_sliver_in.e'
    recover = false
    issues = '#33151'
    requirement = "The system shall be able to repair an interior sliver tetrahedron by edge collapse, producing a valid all-tetrahedral conformal mesh."
    mesh_mode = 'replicated'
  []
  [repair_tet_sliver_skip]
    type = RunApp
    input = repair_tet_sliver_skip.i
    expect_out = 'could not be collapsed \(left in place\): 1'
    issues = '#33151'
    requirement = "The system shall leave a sliver tetrahedron in place, rather than distorting the boundary, when it has no interior node that can be collapsed."
    mesh_mode = 'replicated'
  []
  [repair_tet_sliver_needle]
    type = RunApp
    input = repair_tet_sliver_needle.i
    expect_out = 'repaired by edge collapse: 1'
    issues = '#33151'
    requirement = "The system shall repair high-valence needle sliver tetrahedra (two nearly-adjacent nodes / a short shared edge) by edge collapse, keeping a valid conformal all-tetrahedral mesh."
    mesh_mode = 'replicated'
  []
  [repair_tet_sliver_apex_outside]
    type = RunApp
    input = repair_tet_sliver_apex_outside.i
    expect_out = 'repaired by edge collapse: 1'
    issues = '#33151'
    requirement = "The system shall repair a flat sliver tetrahedron whose apex projects outside its opposite face (caught by the volume test, not the flap test), keeping a valid conformal all-tetrahedral mesh."
    mesh_mode = 'replicated'
  []
  [repair_tet_sliver_cluster]
    type = RunApp
    input = repair_tet_sliver_cluster.i
    expect_out = 'repaired by edge collapse: 1'
    issues = '#33151'
    requirement = "The system shall repair a cluster of adjacent sliver tetrahedra sharing nodes via node-disjoint passes, keeping a valid conformal all-tetrahedral mesh."
    mesh_mode = 'replicated'
  []
  [repair_tet_sliver_high_valence]
    type = RunApp
    input = repair_tet_sliver_high_valence.i
    expect_out = 'repaired by edge collapse: 1'
    issues = '#33151'
    requirement = "The system shall repair a flat sliver tetrahedron at a high-valence interior node, keeping the surrounding neighborhood valid and conformal."
    mesh_mode = 'replicated'
  []
  [repair_tet_sliver_octahedron]
    type = RunApp
    input = repair_tet_sliver_octahedron.i
    expect_out = 'repaired by edge collapse: 1'
    issues = '#33151'
    requirement = "The system shall, when repairing a sliver at an interior node where some candidate edge collapses would invert a neighbor, reject those and commit a valid collapse."
    mesh_mode = 'replicated'
  []
  [repair_tet_sliver_hybrid]
    type = RunApp
    input = repair_tet_sliver_hybrid.i
    expect_out = 'could not be collapsed \(left in place\): 1'
    issues = '#33151'
    requirement = "The system shall leave a sliver tetrahedron in place when its collapse star includes a non-tetrahedral element, rather than corrupting the mesh."
    mesh_mode = 'replicated'
  []
  [repair_pyramid_sliver]
    type = RunApp
    input = repair_pyramid_sliver.i
    expect_out = 'absorbed into a neighbor: 1'
    issues = '#33151'
    requirement = "The system shall repair a flat sliver pyramid by absorbing it into the hexahedron across its quad base, producing a valid conformal polyhedron and keeping its triangular cap faces conformal with their neighbors."
    mesh_mode = 'replicated'
  []
  [repair_pyramid_sliver_polyhedron]
    type = RunApp
    input = repair_pyramid_sliver_polyhedron.i
    expect_out = 'absorbed into a neighbor: 1'
    issues = '#33151'
    requirement = "The system shall repair a flat sliver pyramid whose quad base is shared with a polyhedron, absorbing it into that polyhedron neighbor while keeping the mesh conformal."
    mesh_mode = 'replicated'
  []
  [repair_pyramid_sliver_prism]
    type = RunApp
    input = repair_pyramid_sliver_prism.i
    expect_out = 'absorbed into a neighbor: 1'
    issues = '#33151'
    requirement = "The system shall repair a flat sliver pyramid while keeping a triangular cap face conformal with a prism neighbor."
    mesh_mode = 'replicated'
  []
  [repair_pyramid_sliver_basenode]
    type = RunApp
    input = repair_pyramid_sliver_basenode.i
    expect_out = 'absorbed into a neighbor: 1'
    issues = '#33151'
    requirement = "The system shall repair an asymmetric flat sliver pyramid, whose apex projects inside the quad base but offset toward a corner, by absorbing it into the element across its base."
    mesh_mode = 'replicated'
  []
  [repair_pyramid_sliver_basenode_polyhedron]
    type = RunApp
    input = repair_pyramid_sliver_basenode_polyhedron.i
    expect_out = 'absorbed into a neighbor: 1'
    issues = '#33151'
    requirement = "The system shall repair an asymmetric flat sliver pyramid sharing its quad base with a polyhedron neighbor."
    mesh_mode = 'replicated'
  []
  [repair_pyramid_sliver_basenode_prism]
    type = RunApp
    input = repair_pyramid_sliver_basenode_prism.i
    expect_out = 'absorbed into a neighbor: 1'
    issues = '#33151'
    requirement = "The system shall repair an asymmetric flat sliver pyramid while keeping a triangular cap face conformal with a prism neighbor."
    mesh_mode = 'replicated'
  []
  [repair_pyramid_sliver_thin_base]
    type = RunApp
    input = repair_pyramid_sliver_thin_base.i
    expect_out = 'absorbed into a neighbor: 1'
    issues = '#33151'
    requirement = "The system shall repair a flat sliver pyramid resting on a thin, near-aligned quad base by absorbing it into the thin hexahedron across that base."
    mesh_mode = 'replicated'
  []
  [repair_pyramid_sliver_skip]
    type = RunApp
    input = repair_pyramid_sliver_skip.i
    expect_out = 'could not be absorbed \(left in place\): 1'
    issues = '#33151'
    requirement = "The system shall leave a sliver pyramid in place, rather than corrupting the mesh, when no element shares its quad base and there is nothing to absorb it into."
    mesh_mode = 'replicated'
  []
[]
