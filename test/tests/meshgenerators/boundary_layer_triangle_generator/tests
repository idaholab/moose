[Tests]
  design = 'meshgenerators/BoundaryLayerTriangleGenerator.md'
  issues = '#32515'
  [test]
    requirement = "The system shall be able to "
    [outward]
      type = 'CSVDiff'
      input = 'boundary_layer.i'
      csvdiff = 'boundary_layer_outward.csv'
      recover = false
      detail ='create a boundary layer mesh outside of an existing mesh.'
    []
    [quadratic]
      type = 'CSVDiff'
      input = 'boundary_layer.i'
      csvdiff = 'boundary_layer_quadratic.csv'
      cli_args = '/Mesh/boundary_layer/tri_elem_type=TRI6
                  /Mesh/outer_bdy/edge_element_type=EDGE3
                  /Outputs/file_base=boundary_layer_quadratic'
      recover = false
      detail ='create a boundary layer mesh outside of an existing mesh with quadratic elements.'
    []
    [bdry_names]
      type = 'CSVDiff'
      input = 'boundary_layer.i'
      csvdiff = 'boundary_layer_outward_bcnm.csv'
      cli_args = '/Mesh/boundary_layer/interface_name=interface
                 /Mesh/boundary_layer/surface_name=surface
                 /Postprocessors/bdry_length/type=AreaPostprocessor
                 /Postprocessors/bdry_length/boundary="interface surface"
                 /Outputs/file_base=boundary_layer_outward_bcnm'
      recover = false
      detail ='create a boundary layer mesh outside of an existing mesh with specified boundary names.'
    []
    [inward]
      type = 'CSVDiff'
      input = 'boundary_layer.i'
      csvdiff = 'boundary_layer_inward.csv'
      cli_args = '/Mesh/boundary_layer/boundary_layer_direction=INWARD
                  /Outputs/file_base=boundary_layer_inward'
      recover = false
      detail ='create a boundary layer mesh inside of an existing mesh.'
    []
    [outward_bias_1]
      type = 'CSVDiff'
      input = 'boundary_layer.i'
      csvdiff = 'boundary_layer_outward_bias_1.csv'
      cli_args = '/Mesh/boundary_layer/layer_bias=2.0
                  /Outputs/file_base=boundary_layer_outward_bias_1'
      recover = false
      detail ='create a boundary layer mesh outside of an existing mesh with >1 bias.'
    []
    [outward_bias_2]
      type = 'CSVDiff'
      input = 'boundary_layer.i'
      csvdiff = 'boundary_layer_outward_bias_2.csv'
      cli_args = '/Mesh/boundary_layer/layer_bias=0.5
                  /Outputs/file_base=boundary_layer_outward_bias_2'
      recover = false
      detail ='create a boundary layer mesh outside of an existing mesh with <1 bias.'
    []
    [inward_bias_1]
      type = 'CSVDiff'
      input = 'boundary_layer.i'
      csvdiff = 'boundary_layer_inward_bias_1.csv'
      cli_args = '/Mesh/boundary_layer/layer_bias=2.0
                  /Mesh/boundary_layer/boundary_layer_direction=INWARD
                  /Outputs/file_base=boundary_layer_inward_bias_1'
      recover = false
      detail ='create a boundary layer mesh inside of an existing mesh with >1 bias.'
    []
    [inward_bias_2]
      type = 'CSVDiff'
      input = 'boundary_layer.i'
      csvdiff = 'boundary_layer_inward_bias_2.csv'
      cli_args = '/Mesh/boundary_layer/layer_bias=0.5
                  /Mesh/boundary_layer/boundary_layer_direction=INWARD
                  /Outputs/file_base=boundary_layer_inward_bias_2'
      recover = false
      detail ='create a boundary layer mesh inside of an existing mesh with <1 bias.'
    []
    [keep_input_outward]
      type = 'CSVDiff'
      input = 'boundary_layer_stitch_outward.i'
      csvdiff = 'boundary_layer_stitch_outward.csv'
      recover = false
      detail ='create a boundary layer mesh outside of an existing mesh while keeping the input mesh.'
    []
    [keep_input_inward]
      type = 'CSVDiff'
      input = 'boundary_layer_stitch_inward.i'
      csvdiff = 'boundary_layer_stitch_inward.csv'
      recover = false
      detail ='create a boundary layer mesh inside of an existing mesh while keeping the input mesh.'
    []
  []
[]