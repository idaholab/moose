[Tests]
  design = 'meshgenerators/XYCutMeshByMeshGenerator.md'
  issues = '#28000'
  [convex_cut_inside_tri]
    type = 'Exodiff'
    input = 'convex_cut.i'
    exodiff = 'convex_cut_in.e'
    exodiff_opts = '-pedantic'
    mesh_mode = 'REPLICATED'
    recover = false
    requirement = 'The system shall be able to cut a 2D mesh using the outer boundary of another '
                  'mesh as the cut curve and remove the elements inside the cutter, triangulating '
                  'the clipped pieces.'
    cli_args = '--mesh-only convex_cut_in.e'
  []
  [convex_cut_outside_tri]
    type = 'Exodiff'
    input = 'convex_cut.i'
    exodiff = 'convex_cut_out.e'
    exodiff_opts = '-pedantic'
    mesh_mode = 'REPLICATED'
    recover = false
    requirement = 'The system shall be able to keep only the portion of the primary mesh inside '
                  'the cutter (REMOVE_OUTSIDE mode).'
    cli_args = 'Mesh/cut/mode=REMOVE_OUTSIDE --mesh-only convex_cut_out.e'
  []
  [convex_cut_keep_both_tri]
    type = 'Exodiff'
    input = 'convex_cut.i'
    exodiff = 'convex_cut_both.e'
    exodiff_opts = '-pedantic'
    mesh_mode = 'REPLICATED'
    recover = false
    requirement = 'The system shall be able to split a 2D mesh into two subdomains along the '
                  'cutter polyline, keeping both sides (KEEP_BOTH mode).'
    cli_args = 'Mesh/cut/mode=KEEP_BOTH --mesh-only convex_cut_both.e'
  []
  [convex_cut_inside_poly]
    type = 'Exodiff'
    input = 'convex_cut_poly.i'
    exodiff = 'convex_cut_poly.e'
    exodiff_opts = '-pedantic'
    mesh_mode = 'REPLICATED'
    recover = false
    requirement = 'The system shall be able to cut a 2D mesh using another mesh, emitting '
                  'C0POLYGON elements for the clipped pieces, then convert to TRI3 for output.'
    cli_args = '--mesh-only convex_cut_poly.e'
  []
  [snap]
    type = 'Exodiff'
    input = 'snap.i'
    exodiff = 'snap.e'
    exodiff_opts = '-pedantic'
    mesh_mode = 'REPLICATED'
    recover = false
    requirement = 'The system shall be able to snap primary mesh nodes onto the cutter polyline '
                  'when they are within snap_tol of the polyline, to avoid sliver polygons.'
    cli_args = '--mesh-only snap.e'
  []
  [errors]
    requirement = 'The system shall error'
    [err_non_2d_primary]
      type = 'RunException'
      input = 'convex_cut.i'
      mesh_mode = 'REPLICATED'
      expect_err = 'Only 2D meshes are supported'
      detail = 'if the primary input mesh is not 2D,'
      cli_args = 'Mesh/primary/dim=3 --mesh-only out.e'
    []
    [err_non_2d_cutter]
      type = 'RunException'
      input = 'convex_cut.i'
      mesh_mode = 'REPLICATED'
      expect_err = 'Only 2D meshes are supported'
      detail = 'if the cutter input mesh is not 2D,'
      cli_args = 'Mesh/cutter/dim=3 --mesh-only out.e'
    []
    [err_same_input]
      type = 'RunException'
      input = 'convex_cut.i'
      mesh_mode = 'REPLICATED'
      expect_err = "must be different from 'input'"
      detail = 'if the input and cutter parameters point at the same mesh generator,'
      cli_args = 'Mesh/cut/cutter=primary --mesh-only out.e'
    []
    [err_cutter_winds_in_primary_elem]
      type = 'RunException'
      input = 'convex_cut.i'
      mesh_mode = 'REPLICATED'
      expect_err = 'cutter polyline winds within primary element'
      detail = 'if the cutter polyline dips into a primary element without crossing it (primary '
               'mesh too coarse near the cutter).'
      cli_args = 'Mesh/primary/nx=1 Mesh/primary/ny=2 --mesh-only out.e'
    []
    [err_cutter_fully_inside_primary_elem]
      type = 'RunException'
      input = 'convex_cut.i'
      mesh_mode = 'REPLICATED'
      expect_err = 'cutter polyline winds within primary element'
      detail = 'if the cutter polyline is entirely contained within a single primary element '
               '(primary mesh too coarse).'
      cli_args = 'Mesh/primary/nx=1 Mesh/primary/ny=1 --mesh-only out.e'
    []
  []
[]
