[Tests]
  design = 'meshgenerators/STLSubdomainGenerator.md'
  issues = '#32763'

  [basic_inside]
    type = CSVDiff
    input = basic_inside.i
    csvdiff = basic_inside_out_elem_counter_0001.csv
    requirement = 'The system shall assign a subdomain to 3D mesh elements whose vertex-average points lie inside a closed STL manifold.'
  []

  [outside]
    type = CSVDiff
    input = outside.i
    csvdiff = outside_out_elem_counter_0001.csv
    requirement = 'The system shall assign a subdomain to 3D mesh elements whose vertex-average points lie outside a closed STL manifold.'
  []

  [restricted]
    type = CSVDiff
    input = restricted.i
    csvdiff = restricted_out_elem_counter_0001.csv
    requirement = 'The system shall restrict STL-based subdomain assignment to selected existing subdomains.'
  []

  [rotated_translated]
    type = CSVDiff
    input = rotated_translated.i
    csvdiff = rotated_translated_out_elem_counter_0001.csv
    requirement = 'The system shall support rigid-body rotation and translation of the STL containment geometry.'
  []

  [scaled]
    type = CSVDiff
    input = scaled.i
    csvdiff = scaled_out_elem_counter_0001.csv
    requirement = 'The system shall support scaling STL geometry before rotation and translation for unit conversion workflows.'
  []

  [open_surface_error]
    type = RunException
    input = open_surface_error.i
    cli_args = --mesh-only
    expect_err = 'must define a watertight 2-manifold surface'
    requirement = 'The system shall report an error if the STL surface is open or non-manifold.'
  []

  [invalid_dimension]
    type = RunException
    input = invalid_dimension.i
    cli_args = --mesh-only
    expect_err = 'Only 3D meshes are supported.'
    requirement = 'The system shall report an error if STL subdomain assignment is requested on a non-3D mesh.'
  []
[]
