[Tests]
  design = 'AutomaticMortarGeneration.md'
  issues = '#33378'
  # These finite-difference tests modify mesh coordinates in place. Distributed contact coverage is
  # provided separately without modifying the mesh.
  recover = false # Setup-only finite-difference sensitivity checks do not advance the solve.
  restep = false # Setup-only finite-difference sensitivity checks do not advance the solve.

  [edge2]
    type = RunApp
    mesh_mode = REPLICATED
    input = edge.i
    cli_args = 'Mesh/second_order=false Variables/T/order=FIRST Problem/solve=false Outputs/exodus=false'
    expect_out = 'Verified mortar nodal-normal coordinate sensitivities for EDGE2'
    requirement = 'The framework shall compute coordinate-consistent averaged mortar nodal-normal sensitivities on EDGE2 secondary elements.'
  []
  [edge3]
    type = RunApp
    mesh_mode = REPLICATED
    input = edge.i
    cli_args = 'Problem/solve=false Outputs/exodus=false'
    expect_out = 'Verified mortar nodal-normal coordinate sensitivities for EDGE3'
    requirement = 'The framework shall compute coordinate-consistent averaged mortar nodal-normal sensitivities on EDGE3 secondary elements.'
  []
  [edge3_reversed]
    type = RunApp
    mesh_mode = REPLICATED
    input = edge.i
    cli_args = 'Constraints/mortar/primary_boundary=1 Constraints/mortar/secondary_boundary=2 Constraints/mortar/primary_subdomain=10 Constraints/mortar/secondary_subdomain=20 Variables/lambda/block=20 Problem/solve=false Outputs/exodus=false'
    expect_out = 'Verified mortar nodal-normal coordinate sensitivities for EDGE3'
    requirement = 'The framework shall compute coordinate-consistent averaged mortar nodal-normal sensitivities when the primary and secondary interface orientations are reversed.'
  []
  [edge3_large_scale]
    type = RunApp
    mesh_mode = REPLICATED
    input = edge.i
    cli_args = 'UserObjects/normal_sensitivity/coordinate_scale=1e6 Problem/solve=false Outputs/exodus=false'
    expect_out = 'Verified mortar nodal-normal coordinate sensitivities for EDGE3'
    requirement = 'The framework shall compute scale-independent averaged mortar nodal-normal sensitivities on large EDGE3 secondary elements.'
  []
  [edge3_periodic]
    type = RunApp
    mesh_mode = REPLICATED
    input = periodic.i
    cli_args = 'Problem/solve=false Outputs/exodus=false'
    expect_out = 'Verified mortar nodal-normal coordinate sensitivities for EDGE3'
    requirement = 'The framework shall preserve the periodic orientation sign in averaged mortar nodal-normal sensitivities on EDGE3 secondary elements.'
  []
  [collapsed_edge]
    type = RunException
    mesh_mode = REPLICATED
    input = edge.i
    cli_args = 'UserObjects/normal_sensitivity/collapse_secondary_element=true Problem/solve=false Outputs/exodus=false'
    expect_err = 'non-positive characteristic length'
    requirement = 'The framework shall reject a genuinely collapsed secondary edge when constructing mortar nodal-normal sensitivities.'
  []
