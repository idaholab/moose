[Tests]
  [MFEMScalarVectorProjectionAux]
    type = CSVDiff
    input = projection.i
    csvdiff = 'OutputData/Projection/projection_line_sample_Az_0001.csv '
              'OutputData/Projection/projection_line_sample_GAz_0001.csv '
              'OutputData/Projection/projection_line_sample_GAz_copy_0001.csv '
              'OutputData/Projection/projection_line_sample_J_0001.csv'
    design = 'MFEMScalarProjectionAux.md MFEMVectorProjectionAux.md'
    issues = '#31153'
    requirement = 'The system shall have the ability to project scalar and vector coefficients onto appropriate MFEM auxvariables.'
    capabilities = 'mfem'
    compute_devices = 'cpu cuda'
    max_parallel = 1 # schemadiff with multiple ranks
    recover = false
  []
  [MFEMScalarTimeAverageAux]
    type = CSVDiff
    input = ../kernels/heattransfer.i
    cli_args = 'AuxVariables/inactive="" '
               'AuxKernels/inactive="" '
               'AuxKernels/average_field/time_skip=2 '
               'VectorPostprocessors/line_sample/variable=average_temperature '
               'Outputs/CSV/file_base=OutputData/HeatTransferTimeAverage/ht_time_average'
    csvdiff = 'OutputData/HeatTransferTimeAverage/ht_time_average_line_sample_0001.csv
                OutputData/HeatTransferTimeAverage/ht_time_average_line_sample_0002.csv
                OutputData/HeatTransferTimeAverage/ht_time_average_line_sample_0003.csv'
    design = 'MFEMScalarTimeAverageAux.md'
    issues = '#31163'
    requirement = 'The system shall have the ability to take a running time average of an MFEM variable.'
    capabilities = 'mfem'
    compute_devices = 'cpu cuda'
    max_parallel = 1 # schemadiff with multiple ranks
    recover = false
    restep = false
  []
  [MFEMInnerProductAux]
    type = CSVDiff
    input = ../kernels/curlcurl.i
    cli_args = 'FESpaces/inactive="" '
               'AuxVariables/inactive="" '
               'AuxKernels/inactive="" '
               'Solver/l_tol=1e-15 '
               'VectorPostprocessors/line_sample/variable=joule_heating '
               'Outputs/CSV/file_base=OutputData/InnerProduct/inner_product'
    csvdiff = 'OutputData/InnerProduct/inner_product_line_sample_0001.csv'
    design = 'MFEMInnerProductAux.md'
    issues = '#31613'
    requirement = 'The system shall have the ability to project the inner product of two gridfunctions onto an MFEM auxvariable'
    capabilities = 'mfem'
    compute_devices = 'cpu cuda'
    max_parallel = 1 # schemadiff with multiple ranks
    recover = false
    restep = false
  []
  [MFEMCrossProductAux]
    type = XMLDiff
    input = crossproduct.i
    xmldiff = 'OutputData/CrossProduct/Run0/Run0.pvd
                OutputData/CrossProduct/Run0/Cycle000001/proc000000.vtu'
    design = 'MFEMCrossProductAux.md'
    issues = '#31613'
    requirement = 'The system shall have the ability to project the cross product of two gridfunctions onto an MFEM vector auxvariable'
    capabilities = 'mfem'
    compute_devices = 'cpu cuda'
    max_parallel = 1 # schemadiff with multiple ranks
    recover = false
    restep = false
  []
