[Tests]
  design = 'MFEMPointValueSampler.md'
  issues = '#31249'
  [MFEMPointValueSamplerDiffusion]
    type = CSVDiff
    input = point_value_sampler_diffusion.i
    cli_args = Outputs/active=
    csvdiff = 'point_value_sampler_diffusion_out_point_sample_0001.csv'
    requirement = 'The system shall have the ability to interpolate scalars at arbitrary points using MFEM.'
    capabilities = 'mfem'
    recover = false
    compute_devices = 'cpu cuda'
  []
  [MFEMPointValueSamplerCurlCurl]
    type = CSVDiff
    input = point_value_sampler_curlcurl.i
    cli_args = Outputs/active=
    csvdiff = 'point_value_sampler_curlcurl_out_point_sample_0001.csv'
    requirement = 'The system shall have the ability to interpolate vectors at arbitrary points using MFEM.'
    capabilities = 'mfem'
    recover = false
    compute_devices = 'cpu cuda'
  []
  [MFEMValueSamplerPointNotFoundError]
    type = RunException
    input = point_value_sampler_point_not_found.i
    expect_err = 'MFEMSamplerBase could not find point at'
    requirement = "The system shall issue an error if an attempt is made to sample at a point that is not inside the mesh."
    capabilities = 'mfem'
    recover = false
    compute_devices = 'cpu cuda'
  []
  [MFEMValueSamplerBoundaryDiscontinuousWarning]
    type = RunException
    input = point_value_sampler_boundary_warn.i
    expect_err = "MFEMValueSamplerBase found a point on an element boundary but the FE space is discontinuous at boundaries"
    issues = '#32988'
    requirement = "The system shall issue a warning if an attempt is made to sample a variable near a boundary when the variable is discontinuous across boundaries."
    capabilities = 'mfem'
    recover = false
    compute_devices = 'cpu cuda'
  []
  [MFEMValueSamplerBoundaryTolNotOnBoundary]
    type = RunApp
    input = point_value_sampler_boundary_tol.i
    requirement = "The system shall not issue an error for a point near but outside a boundary when the tolerance is loose."
    capabilities = 'mfem'
    recover = false
    compute_devices = 'cpu cuda'
  []
  [MFEMValueSamplerBoundaryTolOnBoundary]
    type = RunException
    input = point_value_sampler_boundary_tol.i
    expect_err = 'MFEMSamplerBase could not find point at'
    cli_args = 'VectorPostprocessors/point_sample/mesh_boundary_tolerance=1e-10'
    requirement = "The system shall issue an error for a point near but outside a boundary when the tolerance is tight."
    capabilities = 'mfem'
    recover = false
    compute_devices = 'cpu cuda'
  []
  [MFEMPointValueSamplerAvgTypeNone]
    type = CSVDiff
    input = point_value_sampler_boundary_warn.i
    csvdiff = 'OutputData/point_value_sampler_avgtype_none_point_sample_0001.csv'
    cli_args = 'VectorPostprocessors/point_sample/average_type=NONE '
               'Outputs/csv=true '
               'Outputs/file_base=OutputData/point_value_sampler_avgtype_none'
    requirement = 'The system has the ability to use no average near non-continuous boundaries'
    capabilities = 'mfem'
    recover = false
    compute_devices = 'cpu cuda'
    # we will get a warning for being near the boundary
    allow_warnings = 'true'
  []
  [MFEMPointValueSamplerAvgTypeArithmetic]
    type = CSVDiff
    input = point_value_sampler_boundary_warn.i
    csvdiff = 'OutputData/point_value_sampler_avgtype_arithmetic_point_sample_0001.csv'
    cli_args = 'VectorPostprocessors/point_sample/average_type=ARITHMETIC '
               'Outputs/csv=true '
               'Outputs/file_base=OutputData/point_value_sampler_avgtype_arithmetic'
    requirement = 'The system has the ability to use arithmetic average near non-continuous boundaries'
    capabilities = 'mfem'
    recover = false
    compute_devices = 'cpu cuda'
    # we will get a warning for being near the boundary
    allow_warnings = 'true'
  []
  [MFEMPointValueSamplerAvgTypeHarmonic]
    type = CSVDiff
    input = point_value_sampler_boundary_warn.i
    csvdiff = 'OutputData/point_value_sampler_avgtype_harmonic_point_sample_0001.csv'
    cli_args = 'VectorPostprocessors/point_sample/average_type=HARMONIC '
               'Outputs/csv=true '
               'Outputs/file_base=OutputData/point_value_sampler_avgtype_harmonic'
    requirement = 'The system has the ability to use harmonic average near non-continuous boundaries'
    capabilities = 'mfem'
    recover = false
    compute_devices = 'cpu cuda'
    # we will get a warning for being near the boundary
    allow_warnings = 'true'
  []
[]
