[Tests]
  design = MultiAppMFEMShapeEvaluationTransfer.md
  issues = '#31982'
  [MFEM_to_libMesh_sibling_transfers]
    requirement = "The system shall support multiapp sibling transfers from MFEM to libMesh sub-apps via shape function evaluations"
    [nodal_nodal]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'nodal_nodal_libmesh_sub0.e'
      cli_args = "Outputs/file_base=nodal_nodal Transfers/active='mfem_to_libmesh_nodal_nodal'"
      capabilities = 'mfem'
      compute_devices = 'cpu'
      recover = false
      restep = false
      detail = 'between nodal variables,'
    []
    [elem_elem]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'elem_elem_libmesh_sub0.e'
      cli_args = "Outputs/file_base=elem_elem Transfers/active='mfem_to_libmesh_elem_elem'"
      capabilities = 'mfem'
      compute_devices = 'cpu'
      recover = false
      restep = false      
      detail = 'between elemental variables,'
    []    
    [nodal_elem]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'nodal_elem_libmesh_sub0.e'
      cli_args = "Outputs/file_base=nodal_elem Transfers/active='mfem_to_libmesh_nodal_elem'"
      capabilities = 'mfem'
      compute_devices = 'cpu'
      recover = false
      restep = false
      detail = 'from nodal to elemental variables,'
    []
    [1_to_N_nodal]
      type = Exodiff
      input = main_between_multiapp.i
      exodiff = 'mfem_to_libmesh_nodal_1toN_libmesh_sub0.e mfem_to_libmesh_nodal_1toN_libmesh_sub1.e'
      cli_args = "Outputs/file_base=mfem_to_libmesh_nodal_1toN
                  MultiApps/libmesh_sub/positions_objects=libmesh_locs
                  Transfers/active='mfem_to_libmesh_nodal_nodal'"
      capabilities = 'mfem'
      compute_devices = 'cpu'
      recover = false
      restep = false
      detail = 'and from nodal variables sent from one sub-app to multiple sub-apps.'
    []  
  []
  [libMesh_to_MFEM_sibling_transfers]
    requirement = "The system shall support multiapp sibling transfers from libMesh to MFEM sub-apps via shape function evaluations"
    [nodal_nodal]
      type = CSVDiff
      input = main_between_multiapp.i
      csvdiff = 'nodal_nodal_mfem_sub0_nodal_sample_0001.csv'
      cli_args = "Outputs/file_base=nodal_nodal Transfers/active='libmesh_to_mfem_nodal_nodal'
                  MultiApps/mfem_sub/cli_args='Outputs/file_base=nodal_nodal_mfem_sub0;VectorPostprocessors/active=nodal_sample'"
      capabilities = 'mfem'
      compute_devices = 'cpu'
      recover = false
      restep = false
      detail = 'between nodal variables,'
    []
    [elem_elem]
      type = CSVDiff
      input = main_between_multiapp.i
      csvdiff = 'elem_elem_mfem_sub0_elem_sample_0001.csv'
      cli_args = "Outputs/file_base=elem_elem Transfers/active='libmesh_to_mfem_elem_elem'
                  MultiApps/mfem_sub/cli_args='Outputs/file_base=elem_elem_mfem_sub0;VectorPostprocessors/active=elem_sample'"
      capabilities = 'mfem'
      compute_devices = 'cpu'
      recover = false
      restep = false
      detail = 'between elemental variables,'
    []
    [nodal_elem]
      type = CSVDiff
      input = main_between_multiapp.i
      csvdiff = 'nodal_elem_mfem_sub0_elem_sample_0001.csv'
      cli_args = "Outputs/file_base=nodal_elem Transfers/active='libmesh_to_mfem_nodal_elem'
                  MultiApps/mfem_sub/cli_args='Outputs/file_base=nodal_elem_mfem_sub0;VectorPostprocessors/active=elem_sample'"
      capabilities = 'mfem'
      compute_devices = 'cpu'
      recover = false
      restep = false
      detail = 'and from nodal to elemental variables.'
    []
  []
  [MFEM_to_MFEM_sibling_transfers]
    requirement = "The system shall support multiapp sibling transfers from MFEM to MFEM sub-apps via shape function evaluations"
    [1_to_N_nodal]
      type = XMLDiff
      input = mfem_main_between_multiapp.i
      xmldiff = 'OutputData/MFEMtoMFEMSiblingTransfer_mfem_recv0_ParaViewDataCollection/Run0/Run0.pvd
                  OutputData/MFEMtoMFEMSiblingTransfer_mfem_recv0_ParaViewDataCollection/Run0/Cycle000001/proc000000.vtu
                  OutputData/MFEMtoMFEMSiblingTransfer_mfem_recv1_ParaViewDataCollection/Run0/Run0.pvd
                  OutputData/MFEMtoMFEMSiblingTransfer_mfem_recv1_ParaViewDataCollection/Run0/Cycle000001/proc000000.vtu
                  OutputData/MFEMtoMFEMSiblingTransfer_mfem_recv2_ParaViewDataCollection/Run0/Run0.pvd
                  OutputData/MFEMtoMFEMSiblingTransfer_mfem_recv2_ParaViewDataCollection/Run0/Cycle000001/proc000000.vtu'                 
      capabilities = 'mfem'
      compute_devices = 'cpu'
      max_parallel = 1 # XML schemadiff with multiple ranks
      recover = false
      max_threads = 1
      restep = false
      detail = 'between nodal variables from nodal variables sent from one sub-app to multiple sub-apps.'
    []
  []
[]
