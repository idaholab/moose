      type = CSVDiff
      csvdiff = 'oned.csv'
      input = 'test.i'
      detail = 'one dimensional line,'
      cli_args = 'Outputs/out/file_base=oned'
      capabilities = 'mfem'
      recover = false
    []
    [2d]
      type = CSVDiff
      csvdiff = 'twod.csv'
