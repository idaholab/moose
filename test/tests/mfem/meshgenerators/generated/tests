      detail = 'two dimensional rectangle, or'
      cli_args = 'Outputs/out/file_base=twod Mesh/gen/dim=2 Mesh/gen/ny=5'
      capabilities = 'mfem'
      recover = false
    []
    [3d]
      type = CSVDiff
      csvdiff = 'threed.csv'
      input = 'test.i'
      detail = 'three dimensional box.'
