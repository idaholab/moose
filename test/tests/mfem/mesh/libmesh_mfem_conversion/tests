[Tests]
  design = 'source/mfem/utils/BuildMFEMMesh.md'
  issues = '#32520'
  [LibMeshToMFEMMeshQuad]
    requirement = 'It shall be possible to create MFEM meshes from LibMesh ones made up of quads, '
    [run]
      type = RunApp
      input = libmesh_parent.i
      detail = 'verified by running simulations with meshes read both through libMesh and directly from MFEM '
      capabilities = 'mfem'
      recover = false
      compute_devices = 'cpu cuda'
    []
    [verify]
      type = RunCommand
      command = './check.sh libmesh-mesh-square.mesh mfem-mesh-square.mesh'
      detail = "and confirming that the meshes they write to disk are the same."
      capabilities = 'mfem'
      recover = false
      prereq = LibMeshToMFEMMeshQuad/run
    []
  []
