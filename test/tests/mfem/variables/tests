[Tests]
  design = 'MFEMProblem.md MFEMVariable.md'
  [MFEMVariableSetupFromMOOSEVariables]
    issues = '#29632'
    type = XMLDiff
    input = mfem_variables_from_moose.i
    xmldiff = 'OutputData/VariableSetupTest/Run0/Cycle000000/data.pvtu
                OutputData/VariableSetupTest/Run0/Cycle000001/data.pvtu'
    requirement = 'The system shall have the ability to add an MFEM variable from a user specification of a MOOSE variable, inferring the finite element space.'
    capabilities = 'mfem'
    compute_devices = 'cpu cuda'
    max_parallel = 1 # schemadiff with multiple ranks
    recover = false
    restep = false
  []
  [MFEMDiffusionAltSyntax]
    issues = '#32940'
    type = XMLDiff
    input = ../kernels/diffusion.i
    xmldiff = 'OutputData/Diffusion/Run0/Run0.pvd
                OutputData/Diffusion/Run0/Cycle000001/proc000000.vtu'
    cli_args = 'FESpaces/active= '
               'Variables/concentration/type=MooseVariableBase Variables/concentration/family=LAGRANGE Variables/concentration/fespace= '
               'AuxVariables/concentration_gradient/type=MooseVariableBase AuxVariables/concentration_gradient/family=NEDELEC_ONE AuxVariables/concentration_gradient/fespace= '
               'AuxVariables/concentration_grad_curl/type=MooseVariableBase AuxVariables/concentration_grad_curl/family=RAVIART_THOMAS '
               'AuxKernels/curl/type=MFEMCurlAux AuxKernels/curl/variable=concentration_grad_curl AuxKernels/curl/source=concentration_gradient '
               'Postprocessors/conservative/type=MFEMVectorL2Error Postprocessors/conservative/variable=concentration_grad_curl Postprocessors/conservative/function="0 0 0" '
               'Outputs/ParaViewDataCollection/hide=concentration_grad_curl'
    allow_unused = true
    requirement = 'The system shall have the ability to solve a diffusion problem using MFEM with variables created using the traditional syntax.'
    capabilities = 'mfem'
    compute_devices = 'cpu cuda'
    max_parallel = 1 # schemadiff with multiple ranks
    recover = false
  []
[]
