[Tests]
  issues = '#30655'
  design = 'KokkosCopyValueAux.md'
  [copy]
    type = 'CSVDiff'
    input = 'kokkos_copy_aux.i'
    csvdiff = 'kokkos_copy_aux_out_results_0001.csv'
    requirement = 'The Kokkos system shall be able to copy from a variable to another of the same finite element family and order.'
    capabilities = 'kokkos'
    compute_devices = 'cpu cuda'
  []
  [copy_old]
    type = 'CSVDiff'
    input = 'kokkos_copy_old_aux.i'
    csvdiff = 'kokkos_copy_old_aux_out.csv'
    requirement = 'The Kokkos system shall be able to copy from the old and older state of a variable to an auxiliary variable.'
    capabilities = 'kokkos'
    compute_devices = 'cpu cuda'
  []

  # ── MONOMIAL FIRST — native FE and on-demand FE paths ───────────────────────
  # Exercise the Phase 5 (initShapeNative) and Phase 6 (nativeShape(FEShapeKey))
  # code paths for MONOMIAL order > 0.  Both tests compare against the same
  # pre-generated gold CSV file.

  [native_fe_copy_monomial_first]
    type = 'CSVDiff'
    input = 'kokkos_copy_monomial_first_aux.i'
    csvdiff = 'kokkos_copy_monomial_first_aux_out_results_0001.csv'
    requirement = 'The Kokkos native FE path (MOOSE_KOKKOS_NATIVE_FE) shall produce '
                  'correct results when evaluating MONOMIAL FIRST shape functions, '
                  'exercising initShapeNative with a MONOMIAL FEShapeKey.'
    capabilities = 'kokkos & kokkos_native_fe'
    compute_devices = 'cpu cuda'
  []

  [ondemand_fe_copy_monomial_first]
    type = 'CSVDiff'
    input = 'kokkos_copy_monomial_first_aux.i'
    csvdiff = 'kokkos_copy_monomial_first_aux_out_results_0001.csv'
    requirement = 'The Kokkos on-demand FE path (MOOSE_KOKKOS_ONDEMAND_FE) shall produce '
                  'correct results for MONOMIAL FIRST variables, exercising on-device '
                  'nativeShape dispatch via FEShapeKey.'
    capabilities = 'kokkos & kokkos_ondemand_fe'
    compute_devices = 'cpu cuda'
  []
[]
