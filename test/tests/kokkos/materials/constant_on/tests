[Tests]
  issues = '#30655'
  design = 'KokkosMaterials/index.md'

  [constant_on]
    requirement = 'The Kokkos system shall support declaring, computing, and retrieving material properties that are constant on'
    [none]
      type = 'Exodiff'
      input = 'kokkos_constant_on_test.i'
      exodiff = 'kokkos_constant_on_test_out.e'
      detail = 'quadrature points;'
      capabilities = 'kokkos'
      compute_devices = 'cpu cuda'
    []
    [element]
      type = 'Exodiff'
      input = 'kokkos_constant_on_test.i'
      exodiff = 'kokkos_constant_on_test_out.e'
      cli_args = 'Materials/mat/constant_on=ELEMENT'
      detail = 'elements;'
      capabilities = 'kokkos'
      compute_devices = 'cpu cuda'
    []
    [subdomain]
      type = 'Exodiff'
      input = 'kokkos_constant_on_test.i'
      exodiff = 'kokkos_constant_on_test_out.e'
      cli_args = 'Materials/mat/constant_on=SUBDOMAIN'
      detail = 'subdomains;'
      capabilities = 'kokkos'
      compute_devices = 'cpu cuda'
    []
    [mixed]
      type = 'Exodiff'
      input = 'kokkos_mixed_constant_on_test.i'
      exodiff = 'kokkos_constant_on_test_out.e'
      detail = 'quadrature points, elements, and subdomains at the same time on different subdomains.'
      capabilities = 'kokkos'
      compute_devices = 'cpu cuda'
    []
  []

  [error]
    type = 'RunException'
    input = 'kokkos_mixed_constant_on_test.i'
    cli_args = 'Materials/mat_2/block=\'2 3\''
    expect_err = "The declared Kokkos material property 'coef' with constant_on = SUBDOMAIN was already declared as a property with constant_on = ELEMENT on subdomain '3'."
    requirement = "The Kokkos system shall error when a material property was declared by multiple materials with different 'constant_on' options on overlapping subdomains."
    capabilities = 'kokkos'
    compute_devices = 'cpu cuda'
  []
[]
