[Tests]
  issues = '#30655'
  design = 'KokkosADCoupledVarNeumannBC.md'

  [test]
    type = 'Exodiff'
    input = 'kokkos_ad_coupled_var_neumann.i'
    exodiff = 'kokkos_ad_coupled_var_neumann_out.e'
    requirement = 'The Kokkos system shall support coupled Neumann type boundary conditions using automatic differentiation.'
    capabilities = 'kokkos'
    compute_devices = 'cpu cuda'
  []

  [nonlinear]
    requirement = 'When coupling nonlinear variables into a Neumann type boundary condition using automatic differentiation, the Kokkos system shall'
    [exo]
      type = Exodiff
      input = 'kokkos_ad_coupled_var_neumann_nl.i'
      exodiff = 'kokkos_ad_coupled_var_neumann_nl_out.e'
      detail = 'generate accurate results'
      capabilities = 'kokkos'
      compute_devices = 'cpu cuda'
    []
    [jac]
      type = PetscJacobianTester
      run_sim = True
      input = 'kokkos_ad_coupled_var_neumann_nl.i'
      difference_tol = 1e-6
      detail = 'generate a perfect Jacobian'
      capabilities = 'kokkos'
      compute_devices = 'cpu cuda'
    []
  []
[]
