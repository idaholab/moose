[Tests]
  issues = '#31158'
  design = "JunctionComponent.md"
  [1D]
    requirement = "The system shall be able to connect two 1D component's meshes"
    [fill]
      type = Exodiff
      input = 'junction_1D_fill.i'
      exodiff = 'junction_1D_fill_in.e'
      cli_args = '--mesh-only junction_1D_fill_in.e'
      detail = 'by meshing the space between them,'
    []
    [stitch]
